@model IEnumerable<ControlLibrería.Models.ViewModels.SaleIndexViewModel>
@inject ControlLibrería.Services.IConfigurationService Config
@{
    ViewData["Title"] = "Historial de Ventas";
    var symbol = await Config.GetCurrencySymbolAsync();
}

<!-- Page Heading & Actions -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Historial de Ventas</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Registro completo de transacciones realizadas</p>
        </div>
        <!-- Date Filter -->
        <div class="flex items-center gap-3">
            <div class="flex items-center gap-2 bg-gray-50 dark:bg-gray-800 rounded-lg p-1">
                <select id="periodFilter" onchange="handlePeriodChange()" class="h-9 rounded-lg bg-transparent border-none px-3 text-sm focus:ring-2 focus:ring-primary/20 text-[#111418] dark:text-white cursor-pointer">
                    @if (ViewBag.Period == "day")
                    {
                        <option value="day" selected>Hoy</option>
                    }
                    else
                    {
                        <option value="day">Hoy</option>
                    }
                    @if (ViewBag.Period == "week")
                    {
                        <option value="week" selected>Últimos 7 Días</option>
                    }
                    else
                    {
                        <option value="week">Últimos 7 Días</option>
                    }
                    @if (ViewBag.Period == "month")
                    {
                        <option value="month" selected>Este Mes</option>
                    }
                    else
                    {
                        <option value="month">Este Mes</option>
                    }
                    @if (ViewBag.Period == "custom")
                    {
                        <option value="custom" selected>Personalizado</option>
                    }
                    else
                    {
                        <option value="custom">Personalizado</option>
                    }
                </select>
            </div>
            <div id="customDateInputs" class="@(ViewBag.Period == "custom" ? "" : "hidden") flex items-center gap-2">
                <input type="date" id="customStartDate" value="@ViewBag.StartDate" class="h-9 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-3 text-sm text-[#111418] dark:text-white" />
                <span class="text-gray-400">-</span>
                <input type="date" id="customEndDate" value="@ViewBag.EndDate" class="h-9 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-3 text-sm text-[#111418] dark:text-white" />
                <button onclick="applyCustomFilter()" class="h-9 px-4 rounded-lg bg-primary text-white text-sm font-medium hover:bg-blue-600 transition-colors">
                    Aplicar
                </button>
            </div>
            <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                Nueva Venta
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[800px] text-left">
                    <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                        <tr>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">ID Venta</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Vendedor</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Cliente</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha y Hora</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Productos</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Pago</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Total</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Estado</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="text-sm font-mono font-bold text-primary">#@item.Id.ToString("D5")</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <div class="size-6 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-[10px] font-bold text-blue-500">
                                            @(item.SellerName?.Substring(0, 1).ToUpper() ?? "S")
                                        </div>
                                        <span class="text-xs font-medium text-[#111418] dark:text-white">@item.SellerName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[16px] text-[#617589]">person</span>
                                        <span class="text-xs text-[#111418] dark:text-white">@item.CustomerName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-[#111418] dark:text-white">@item.Date.ToString("dd MMM yyyy")</span>
                                        <span class="text-xs text-[#617589] dark:text-gray-400">@item.Date.ToString("hh:mm tt")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @{
                                        var itemsCount = item.SaleDetails?.Sum(d => d.Quantity) ?? 0;
                                    }
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px] text-[#617589]">package_2</span>
                                        <span class="text-sm text-[#111418] dark:text-white">@itemsCount items</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.PaymentMethodName == "Efectivo")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-1 text-xs font-bold text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                            <span class="material-symbols-outlined text-[14px]">payments</span>
                                            Efectivo
                                        </span>
                                    }
                                    else if (item.PaymentMethodName == "Tarjeta")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-2 py-1 text-xs font-bold text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                                            <span class="material-symbols-outlined text-[14px]">credit_card</span>
                                            Tarjeta
                                        </span>
                                    }
                                    else if (item.PaymentMethodName == "Transferencia")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-purple-100 px-2 py-1 text-xs font-bold text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">
                                            <span class="material-symbols-outlined text-[14px]">account_balance</span>
                                            Transfer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2 py-1 text-xs font-bold text-gray-700 dark:bg-gray-800 dark:text-gray-400">
                                            <span class="material-symbols-outlined text-[14px]">payments</span>
                                            Mixto
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.StatusName == "Activa")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-1 text-xs font-bold text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                            Activa
                                        </span>
                                    }
                                    else if (item.StatusName == "Parcialmente Devuelta")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-2 py-1 text-xs font-bold text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
                                            Parcial
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2 py-1 text-xs font-bold text-red-700 dark:bg-red-900/30 dark:text-red-400">
                                            Cancelada
                                        </span>
                                    }

                                    @if(item.HasRefunds)
                                    {
                                         <div class="text-xs text-red-500 mt-1 font-medium">
                                            -@symbol@item.RefundedAmount.ToString("N2")
                                         </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-base font-black text-[#111418] dark:text-white"> @(symbol + item.Total.ToString("N2"))</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 sm:opacity-0 transition-opacity group-hover:opacity-100">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs font-bold bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all">
                                            <span class="material-symbols-outlined text-[18px]">receipt</span>
                                        </a>
                                        
                                        @if (item.StatusName != "Cancelada")
                                        {
                                            <a asp-controller="SaleRefunds" asp-action="Create" asp-route-saleId="@item.Id" class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs font-bold bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all" title="Devolución">
                                                <span class="material-symbols-outlined text-[18px]">undo</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function handlePeriodChange() {
            const period = document.getElementById('periodFilter').value;
            const customInputs = document.getElementById('customDateInputs');
            
            if (period === 'custom') {
                customInputs.classList.remove('hidden');
            } else {
                customInputs.classList.add('hidden');
                // Reload page with new period
                window.location.href = `/ventas?period=${period}`;
            }
        }

        function applyCustomFilter() {
            const startDate = document.getElementById('customStartDate').value;
            const endDate = document.getElementById('customEndDate').value;
            
            if (!startDate || !endDate) {
                showToast('Por favor selecciona ambas fechas', 'error');
                return;
            }
            
            window.location.href = `/ventas?period=custom&startDate=${startDate}&endDate=${endDate}`;
        }
    </script>
}
