@model ControlLibrería.Models.Entities.Product
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="p-6">
    <div class="mx-auto max-w-[500px] flex flex-col gap-6 pt-12">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-xl overflow-hidden">
            <div class="p-8 flex flex-col items-center text-center gap-4">
                <div class="size-20 bg-red-50 dark:bg-red-900/20 rounded-full flex items-center justify-center mb-2">
                    <span class="material-symbols-outlined text-red-500 text-[40px]">delete_forever</span>
                </div>
                <h3 class="text-xl font-bold text-[#111418] dark:text-white">¿Eliminar Producto?</h3>
                <p class="text-sm text-[#617589] dark:text-gray-400">
                    Estás a punto de eliminar <span class="font-bold text-[#111418] dark:text-white">"@Model.Name"</span> del inventario. 
                    Esta acción es irreversible y afectará los registros históricos.
                </p>

                <div class="w-full bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 mt-2 flex items-center gap-4">
                    <div class="size-12 rounded-lg overflow-hidden bg-white border border-gray-100 dark:border-gray-700 shrink-0">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
                            <img src="@Model.ImageUrl" class="h-full w-full object-cover" />
                        } else {
                            <div class="h-full w-full flex items-center justify-center text-gray-300">
                                <span class="material-symbols-outlined">image</span>
                            </div>
                        }
                    </div>
                    <div class="text-left overflow-hidden">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-none mb-1">SKU: @(Model.Barcode ?? "N/A")</p>
                        <p class="text-sm font-bold text-[#111418] dark:text-white truncate">@Model.Name</p>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center gap-0 border-t border-[#f0f2f4] dark:border-gray-800">
                <a asp-action="Index" class="flex-1 h-16 flex items-center justify-center text-sm font-bold text-[#617589] hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors border-r border-[#f0f2f4] dark:border-gray-800">
                    Cancelar
                </a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="w-full h-16 flex items-center justify-center text-sm font-bold text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                        Confirmar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
