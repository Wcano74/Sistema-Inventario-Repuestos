@model ControlLibrería.Models.Entities.Product
@inject ControlLibrería.Services.IConfigurationService Config
@{
    ViewData["Title"] = "Nuevo Producto";
    var symbol = await Config.GetCurrencySymbolAsync();
}

<!-- Page Heading -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1000px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Nuevo Producto</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Añade un nuevo ítem al catálogo de inventario</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Cancelar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[800px]">
        <form asp-action="Create" class="flex flex-col gap-6">
            <div asp-validation-summary="ModelOnly" class="rounded-xl bg-red-50 p-4 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400"></div>
            
            <!-- General Information Card -->
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">info</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Información General</h3>
                </div>
                <div class="p-8 flex flex-col gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="Name" class="text-sm font-semibold text-[#111418] dark:text-white">Nombre del Producto</label>
                        <input asp-for="Name" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Ej: Libro El Principito" />
                        <span asp-validation-for="Name" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Description" class="text-sm font-semibold text-[#111418] dark:text-white">Descripción</label>
                        <textarea asp-for="Description" rows="3" class="rounded-lg border border-[#dbe0e6] bg-white p-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Breve descripción del producto..."></textarea>
                        <span asp-validation-for="Description" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Barcode" class="text-sm font-semibold text-[#111418] dark:text-white">Código de Barras / SKU</label>
                        <input asp-for="Barcode" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white font-mono" placeholder="Ej: BK-123456" />
                        <span asp-validation-for="Barcode" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Brand" class="text-sm font-semibold text-[#111418] dark:text-white">Marca / Fabricante</label>
                        <input asp-for="Brand" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Ej: Editorial Planeta" />
                        <span asp-validation-for="Brand" class="text-xs text-red-500"></span>
                    </div>
                </div>
            </div>

            <!-- Pricing & Stock Card -->
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">sell</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Precios e Inventario</h3>
                </div>
                <div class="p-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="Price" class="text-sm font-semibold text-[#111418] dark:text-white">Precio de Venta</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold">@symbol</span>
                            <input asp-for="Price" class="h-11 w-full rounded-lg border border-[#dbe0e6] bg-white pl-8 pr-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-xs text-red-500"></span>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label asp-for="Cost" class="text-sm font-semibold text-[#111418] dark:text-white">Costo de Compra</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold">@symbol</span>
                            <input asp-for="Cost" class="h-11 w-full rounded-lg border border-[#dbe0e6] bg-white pl-8 pr-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Cost" class="text-xs text-red-500"></span>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label asp-for="StockQuantity" class="text-sm font-semibold text-[#111418] dark:text-white">Stock Inicial</label>
                        <input asp-for="StockQuantity" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" type="number" />
                        <span asp-validation-for="StockQuantity" class="text-xs text-red-500"></span>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label asp-for="MinStock" class="text-sm font-semibold text-[#111418] dark:text-white">Stock Mínimo (Alerta)</label>
                        <input asp-for="MinStock" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" type="number" />
                        <span asp-validation-for="MinStock" class="text-xs text-red-500"></span>
                    </div>
                </div>
            </div>

            <!-- categorization Card -->
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">category</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Clasificación</h3>
                </div>
                <div class="p-8 flex flex-col gap-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label asp-for="CategoryId" class="text-sm font-semibold text-[#111418] dark:text-white">Categoría</label>
                            <select asp-for="CategoryId" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" asp-items="ViewBag.CategoryId"></select>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label asp-for="SupplierId" class="text-sm font-semibold text-[#111418] dark:text-white">Proveedor</label>
                            <select asp-for="SupplierId" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" asp-items="ViewBag.SupplierId">
                                <option value="">-- Seleccionar Proveedor --</option>
                            </select>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label asp-for="ImageUrl" class="text-sm font-semibold text-[#111418] dark:text-white">URL de la Imagen</label>
                        <input asp-for="ImageUrl" class="h-11 rounded-lg border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="https://ejemplo.com/imagen.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-xs text-red-500"></span>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-3 py-4">
                <a asp-action="Index" class="h-12 px-6 flex items-center justify-center rounded-xl border border-[#dbe0e6] text-[#111418] dark:border-gray-800 dark:text-white hover:bg-gray-50 transition-colors font-bold">Cancelar</a>
                <button type="submit" class="h-12 px-10 flex items-center justify-center rounded-xl bg-primary text-white shadow-lg shadow-blue-500/30 hover:bg-blue-600 transition-all font-bold">
                    Guardar Producto
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
