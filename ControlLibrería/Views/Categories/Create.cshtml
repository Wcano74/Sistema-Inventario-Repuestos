@model ControlLibrería.Models.Entities.Category
@{
    ViewData["Title"] = "Nueva Categoría";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[800px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Nueva Categoría</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Crea un nuevo grupo para organizar tus productos</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Cancelar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[600px]">
        <form asp-action="Create" class="flex flex-col gap-6">
            <div asp-validation-summary="ModelOnly" class="rounded-xl bg-red-50 p-4 text-sm text-red-600 dark:bg-red-900/20 dark:text-red-400"></div>
            
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">category</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Detalles de la Categoría</h3>
                </div>
                <div class="p-8 flex flex-col gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="Name" class="text-sm font-semibold text-[#111418] dark:text-white">Nombre de la Categoría</label>
                        <input asp-for="Name" class="h-12 rounded-xl border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Ej: Papelería, Libros, Electrónica" />
                        <span asp-validation-for="Name" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label asp-for="Description" class="text-sm font-semibold text-[#111418] dark:text-white">Descripción (Opcional)</label>
                        <textarea asp-for="Description" rows="3" class="rounded-xl border border-[#dbe0e6] bg-white p-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Describe brevemente qué productos pertenecen a esta categoría..."></textarea>
                        <span asp-validation-for="Description" class="text-xs text-red-500"></span>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-3 py-4">
                <a asp-action="Index" class="h-12 px-6 flex items-center justify-center rounded-xl border border-[#dbe0e6] text-[#111418] dark:border-gray-800 dark:text-white hover:bg-gray-50 transition-colors font-bold">Cancelar</a>
                <button type="submit" class="h-12 px-10 flex items-center justify-center rounded-xl bg-primary text-white shadow-lg shadow-blue-500/30 hover:bg-blue-600 transition-all font-bold">
                    Guardar Categoría
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
