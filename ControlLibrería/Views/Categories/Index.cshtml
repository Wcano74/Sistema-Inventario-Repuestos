@model IEnumerable<ControlLibrería.Models.Entities.Category>
@{
    ViewData["Title"] = "Categorías";
}

<!-- Page Heading & Actions -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Categorías</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Organiza tus productos por grupos lógicos</p>
        </div>
        <div class="flex items-center gap-3">
            @if (ViewBag.CanEditStock == true)
            {
                <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                    <span class="material-symbols-outlined text-[20px]">add</span>
                    Nueva Categoría
                </a>
            }
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[600px] text-left">
                    <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                        <tr>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Nombre</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Descripción</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Productos</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                            <span class="material-symbols-outlined text-[20px]">category</span>
                                        </div>
                                        <span class="text-sm font-bold text-[#111418] dark:text-white">@item.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm text-[#617589] dark:text-gray-400">@item.Description</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <span class="px-2 py-1 rounded-md bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-xs font-bold">
                                            @item.Products.Count
                                        </span>
                                        <span class="text-xs text-[#617589] dark:text-gray-400">@(item.Products.Count == 1 ? "Producto" : "Productos")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 sm:opacity-0 transition-opacity group-hover:opacity-100">
                                        @if (ViewBag.CanEditStock == true)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#617589] hover:border-primary hover:text-primary dark:border-gray-800 dark:bg-surface-dark transition-all" title="Editar">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#617589] hover:border-blue-500 hover:text-blue-500 dark:border-gray-800 dark:bg-surface-dark transition-all" title="Detalles">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        </a>
                                        @if (ViewBag.CanEditStock == true)
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-red-400 hover:border-red-500 hover:text-red-500 dark:border-gray-800 dark:bg-surface-dark transition-all" title="Eliminar">
                                                <span class="material-symbols-outlined text-[18px]">delete</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
