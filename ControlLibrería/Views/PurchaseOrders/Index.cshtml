@model IEnumerable<ControlLibrería.Models.Entities.PurchaseOrder>
@inject Microsoft.AspNetCore.Identity.UserManager<ControlLibrería.Models.Entities.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Pedidos a Proveedores";
    var currentUser = await UserManager.GetUserAsync(User);
    var canCreate = User.IsInRole("Admin") || (currentUser != null && currentUser.CanCreateOrders);
}

<!-- Page Heading & Actions -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Pedidos a Proveedores</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Gestiona tus órdenes de compra y reabastecimiento</p>
        </div>
        <div class="flex items-center gap-3">
            @if (canCreate)
            {
             <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Nuevo Pedido
            </a>
            }
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        
        <!-- Stats / Overview (Optional) -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div class="flex flex-col gap-2 rounded-xl border border-[#dbe0e6] bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                 <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-[#617589] dark:text-gray-400">Total Pedidos</p>
                    <span class="material-symbols-outlined text-primary text-[24px]">list_alt</span>
                </div>
                <p class="text-2xl font-bold leading-tight text-[#111418] dark:text-white">@Model.Count()</p>
            </div>
             <div class="flex flex-col gap-2 rounded-xl border border-[#dbe0e6] bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                 <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-[#617589] dark:text-gray-400">Pendientes</p>
                    <span class="material-symbols-outlined text-yellow-500 text-[24px]">pending_actions</span>
                </div>
                <p class="text-2xl font-bold leading-tight text-[#111418] dark:text-white">@Model.Count(x => x.Status == ControlLibrería.Models.Entities.PurchaseOrderStatus.Pending)</p>
            </div>
        </div>

        <!-- Filters -->
        <form method="get" class="flex flex-col gap-4 rounded-xl border border-[#dbe0e6] bg-white p-4 shadow-sm lg:flex-row lg:items-center lg:justify-between dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="flex flex-wrap items-center gap-4 w-full">
                <div class="flex flex-col gap-1 flex-1 min-w-[200px]">
                    <label class="text-xs font-medium text-[#617589] dark:text-gray-400">Proveedor</label>
                    <select name="supplierId" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" asp-items="ViewBag.Suppliers">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1 flex-1 min-w-[200px]">
                     <label class="text-xs font-medium text-[#617589] dark:text-gray-400">Estado</label>
                    <select name="status" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" asp-items="Html.GetEnumSelectList<ControlLibrería.Models.Entities.PurchaseOrderStatus>()">
                        <option value="">-- Todos --</option>
                    </select>
                </div>
                <div class="flex items-end pb-0.5">
                    <button type="submit" class="flex h-10 items-center justify-center rounded-lg bg-primary/10 px-6 text-primary text-sm font-bold hover:bg-primary/20 transition-colors">
                        Filtrar
                    </button>
                </div>
            </div>
        </form>

        <!-- Table -->
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-[#111418] dark:text-white">
                    <thead class="border-b border-[#dbe0e6] bg-gray-50 text-xs uppercase text-[#617589] dark:border-gray-800 dark:bg-gray-800/50 dark:text-gray-400">
                        <tr>
                            <th class="px-4 py-3 font-medium"># ID</th>
                            <th class="px-4 py-3 font-medium">Fecha</th>
                            <th class="px-4 py-3 font-medium">Proveedor</th>
                            <th class="px-4 py-3 font-medium text-right">Total</th>
                            <th class="px-4 py-3 font-medium text-center">Estado</th>
                            <th class="px-4 py-3 font-medium text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#dbe0e6] dark:divide-gray-800">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-4 py-3 font-medium">@item.Id</td>
                                <td class="px-4 py-3 text-[#617589] dark:text-gray-400">@item.OrderDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-3 font-medium">@(item.Supplier?.Name ?? "-")</td>
                                <td class="px-4 py-3 text-right font-medium">@item.TotalAmount.ToString("C")</td>
                                <td class="px-4 py-3 text-center">
                                    @if (item.Status == ControlLibrería.Models.Entities.PurchaseOrderStatus.Pending)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                                            Pendiente
                                        </span>
                                    }
                                    else if (item.Status == ControlLibrería.Models.Entities.PurchaseOrderStatus.Received)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
                                            Recibido
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
                                            Cancelado
                                        </span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="inline-flex items-center justify-center rounded-lg p-2 text-[#617589] hover:bg-gray-100 hover:text-primary dark:text-gray-400 dark:hover:bg-gray-800 transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 text-[#617589] dark:text-gray-400">
                    <span class="material-symbols-outlined mb-2 text-4xl">inbox</span>
                    <p class="text-sm">No se encontraron pedidos</p>
                </div>
            }
        </div>
    </div>
</div>
