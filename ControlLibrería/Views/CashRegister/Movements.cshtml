@model ControlLibrería.Models.ViewModels.CashRegisterSummaryViewModel
@{
    ViewData["Title"] = "Movimientos de Caja";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[1400px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="flex-1">
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Movimientos de Caja</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm"> 
                Sesión del @Model.CashRegister.OpenedAt.ToString("dd/MM/yyyy HH:mm")
                @if (Model.CashRegister.IsOpen)
                {
                    <span class="ml-2 inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                        Abierta
                    </span>
                }
            </p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1400px] mx-auto space-y-6">
        
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/30">
                        <span class="material-symbols-outlined text-[24px]">account_balance_wallet</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Monto Inicial</p>
                        <p class="text-lg font-bold text-[#111418] dark:text-white">Q @Model.CashRegister.OpeningBalance.ToString("N2")</p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600 dark:bg-green-900/30">
                        <span class="material-symbols-outlined text-[24px]">payments</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Efectivo</p>
                        <p class="text-lg font-bold text-green-600">Q @Model.TotalCash.ToString("N2")</p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-100 text-purple-600 dark:bg-purple-900/30">
                        <span class="material-symbols-outlined text-[24px]">credit_card</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Tarjeta</p>
                        <p class="text-lg font-bold text-purple-600">Q @Model.TotalCard.ToString("N2")</p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-100 text-orange-600 dark:bg-orange-900/30">
                        <span class="material-symbols-outlined text-[24px]">receipt_long</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase">Transacciones</p>
                        <p class="text-lg font-bold text-[#111418] dark:text-white">@Model.TransactionCount</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sales Table -->
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800">
                <h3 class="text-lg font-bold text-[#111418] dark:text-white">Detalle de Ventas</h3>
            </div>
            
            @if (Model.Sales.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                            <tr>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Hora</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Cliente</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Método de Pago</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Items</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                            @foreach (var sale in Model.Sales)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                                    <td class="px-6 py-4 text-sm text-[#111418] dark:text-white">
                                        @sale.Date.ToString("HH:mm")
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                                        @(sale.Customer?.Name ?? "Cliente General")
                                    </td>
                                    <td class="px-6 py-4">
                                        @switch (sale.PaymentMethod)
                                        {
                                            case ControlLibrería.Models.Entities.PaymentMethod.Cash:
                                                <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-1 text-xs font-bold text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                                    <span class="material-symbols-outlined text-[14px]">payments</span>
                                                    Efectivo
                                                </span>
                                                break;
                                            case ControlLibrería.Models.Entities.PaymentMethod.Card:
                                                <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-2 py-1 text-xs font-bold text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                                                    <span class="material-symbols-outlined text-[14px]">credit_card</span>
                                                    Tarjeta
                                                </span>
                                                break;
                                            case ControlLibrería.Models.Entities.PaymentMethod.Transfer:
                                                <span class="inline-flex items-center gap-1 rounded-full bg-purple-100 px-2 py-1 text-xs font-bold text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">
                                                    <span class="material-symbols-outlined text-[14px]">account_balance</span>
                                                    Transferencia
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                                        @sale.SaleDetails.Count
                                    </td>
                                    <td class="px-6 py-4 text-right text-sm font-bold text-[#111418] dark:text-white">
                                        Q @sale.Total.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-t-2 border-[#dbe0e6] dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
                            <tr>
                                <td colspan="4" class="px-6 py-4 text-right text-sm font-bold text-[#111418] dark:text-white">
                                    TOTAL
                                </td>
                                <td class="px-6 py-4 text-right text-lg font-bold text-primary">
                                    Q @((Model.TotalCash + Model.TotalCard + Model.TotalTransfer + Model.TotalMixed).ToString("N2"))
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="p-12 text-center">
                    <div class="flex justify-center mb-4">
                        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800">
                            <span class="material-symbols-outlined text-[32px] text-gray-400">receipt_long</span>
                        </div>
                    </div>
                    <p class="text-sm text-gray-500">No hay ventas registradas en esta sesión</p>
                </div>
            }
        </div>
    </div>
</div>
