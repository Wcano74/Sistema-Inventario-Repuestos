@model ControlLibrería.Models.Entities.CashRegister
@{
    ViewData["Title"] = "Abrir Caja";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[800px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Abrir Caja</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Inicia una nueva sesión de caja</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[600px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <form asp-action="Open" method="post" class="p-8">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                
                <div class="flex items-center justify-center mb-8">
                    <div class="flex h-20 w-20 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
                        <span class="material-symbols-outlined text-[48px]">lock_open</span>
                    </div>
                </div>

                <div class="mb-6">
                    <label asp-for="OpeningBalance" class="block text-sm font-bold text-[#111418] dark:text-white mb-2">Monto Inicial en Efectivo</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">Q</span>
                        <input asp-for="OpeningBalance" type="number" step="0.01" min="0" class="w-full h-14 rounded-xl bg-gray-50 dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 pl-10 pr-4 text-lg font-bold focus:ring-2 focus:ring-primary/20 focus:border-primary" required />
                    </div>
                    <span asp-validation-for="OpeningBalance" class="text-red-500 text-xs"></span>
                    <p class="text-xs text-gray-500 mt-2">Ingresa el monto en efectivo con el que inicias la caja (billetes y monedas)</p>
                </div>

                <div class="mb-8">
                    <label asp-for="OpeningNotes" class="block text-sm font-bold text-[#111418] dark:text-white mb-2">Notas de Apertura (Opcional)</label>
                    <textarea asp-for="OpeningNotes" rows="3" class="w-full rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20" placeholder="Ej: 3 billetes de Q100, 2 de Q50..."></textarea>
                    <span asp-validation-for="OpeningNotes" class="text-red-500 text-xs"></span>
                </div>

                <div class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-900/50 mb-8">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-[24px]">info</span>
                        <div>
                            <p class="text-sm font-bold text-blue-900 dark:text-blue-400 mb-1">Importante</p>
                            <p class="text-xs text-blue-700 dark:text-blue-500">Una vez abierta la caja, todas las ventas en efectivo se registrarán en esta sesión hasta que la cierres.</p>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3">
                    <a asp-action="Index" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-3 px-8 rounded-xl hover:bg-gray-300 dark:hover:bg-gray-600 transition-all">
                        Cancelar
                    </a>
                    <button type="submit" class="bg-green-600 text-white font-bold py-3 px-8 rounded-xl shadow-xl shadow-green-500/30 hover:bg-green-700 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">lock_open</span>
                        Abrir Caja
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
