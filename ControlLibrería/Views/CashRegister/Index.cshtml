@model IEnumerable<ControlLibrería.Models.Entities.CashRegister>
@{
    ViewData["Title"] = "Registro de Caja";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Registro de Caja</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Gestiona las sesiones de caja y arqueos</p>
        </div>
        <div class="flex items-center gap-3">
            @if (ViewBag.HasOpenCashRegister != true)
            {
                <a asp-action="Open" class="flex items-center justify-center gap-2 rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-green-500/20 transition-colors hover:bg-green-700">
                    <span class="material-symbols-outlined text-[20px]">lock_open</span>
                    Abrir Caja
                </a>
            }
            else
            {
                <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                    <span class="text-sm font-bold">Caja Abierta</span>
                </div>
            }
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[900px] text-left">
                    <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                        <tr>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Estado</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Usuario</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Apertura</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Cierre</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Monto Inicial</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Balance Final</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Diferencia</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4">
                                    @if (item.IsOpen)
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-bold text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                            <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                                            Abierta
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-xs font-bold text-gray-700 dark:bg-gray-800 dark:text-gray-400">
                                            <span class="material-symbols-outlined text-[14px]">lock</span>
                                            Cerrada
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400 text-xs font-bold">
                                            @(item.User?.FirstName?.Substring(0, 1) ?? "U")
                                        </div>
                                        <span class="text-sm font-bold text-[#111418] dark:text-white">@(item.User?.DisplayName ?? "Usuario")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm text-[#111418] dark:text-white">@item.OpenedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.ClosedAt.HasValue)
                                    {
                                        <span class="text-sm text-[#111418] dark:text-white">@item.ClosedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-gray-400 italic">-</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="text-sm font-bold text-[#111418] dark:text-white">Q @item.OpeningBalance.ToString("N2")</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if (!item.IsOpen)
                                    {
                                        <span class="text-sm font-bold text-[#111418] dark:text-white">Q @item.ActualBalance.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-gray-400 italic">-</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if (!item.IsOpen)
                                    {
                                        if (item.Difference == 0)
                                        {
                                            <span class="inline-flex items-center gap-1 text-sm font-bold text-green-600 dark:text-green-400">
                                                <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                                Q 0.00
                                            </span>
                                        }
                                        else if (item.Difference > 0)
                                        {
                                            <span class="text-sm font-bold text-blue-600 dark:text-blue-400">+Q @item.Difference.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-sm font-bold text-red-600 dark:text-red-400">Q @item.Difference.ToString("N2")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-sm text-gray-400 italic">-</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2 sm:opacity-0 transition-opacity group-hover:opacity-100">
                                        <a asp-action="Movements" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#617589] hover:border-blue-500 hover:text-blue-500 dark:border-gray-800 dark:bg-surface-dark transition-all" title="Ver Movimientos">
                                            <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                                        </a>
                                        @if (item.IsOpen)
                                        {
                                            <a asp-action="Close" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-red-500 hover:border-red-500 hover:text-red-600 dark:border-gray-800 dark:bg-surface-dark transition-all" title="Cerrar Caja">
                                                <span class="material-symbols-outlined text-[18px]">lock</span>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
