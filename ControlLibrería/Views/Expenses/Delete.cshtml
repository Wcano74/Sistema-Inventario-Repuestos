@model ControlLibrería.Models.Entities.Expense
@{
    ViewData["Title"] = "Eliminar Egreso";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[600px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight text-red-600">Eliminar Egreso</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Esta acción no se puede deshacer</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[600px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-red-100 dark:border-red-900/30 shadow-sm overflow-hidden text-center p-10">
            <div class="size-20 bg-red-50 dark:bg-red-900/20 text-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-[40px]">warning</span>
            </div>
            
            <h3 class="text-2xl font-bold text-[#111418] dark:text-white mb-2">¿Confirmar eliminación?</h3>
            <div class="bg-gray-50 dark:bg-gray-800/50 rounded-2xl p-6 mb-8 text-left">
                <div class="flex justify-between items-center mb-4 pb-4 border-b border-gray-100 dark:border-gray-700">
                    <span class="text-xs font-bold text-gray-500 uppercase">Monto</span>
                    <span class="text-lg font-black text-red-600">@Model.Amount.ToString("C")</span>
                </div>
                <div class="space-y-2">
                    <p class="text-sm font-bold text-[#111418] dark:text-white">@Model.Description</p>
                    <p class="text-xs text-gray-500">Categoría: @(Model.Category?.Name ?? "General")</p>
                    <p class="text-xs text-gray-500">Fecha: @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="flex flex-col gap-3">
                    <button type="submit" class="bg-red-600 text-white font-bold py-4 px-8 rounded-xl shadow-lg shadow-red-500/20 hover:bg-red-700 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">delete_forever</span>
                        Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="py-3 text-sm font-bold text-gray-500 hover:text-gray-700 transition-all">Cancelar y Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>
