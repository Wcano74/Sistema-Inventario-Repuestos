@model IEnumerable<ControlLibrería.Models.Entities.InventoryCycle>
@using ControlLibrería.Models.Entities

@{
    ViewData["Title"] = "Ciclos de Inventario";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center justify-between max-w-[1200px] mx-auto">
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Ciclos de Inventario</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Gestiona auditorías y tomas de inventario</p>
        </div>
        <a asp-action="Create" class="bg-blue-600 text-white font-bold py-2 px-4 rounded-xl shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:-translate-y-0.5 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">add</span>
            <span>Nuevo Inventario</span>
        </a>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1200px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Fecha Apertura</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Estado</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Alcance</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Responsable</th>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Fecha Cierre</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var item in Model) {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4 text-sm font-bold text-gray-900 dark:text-white">#@item.Id</td>
                                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">@item.OpenedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4">
                                    @if(item.Status == CycleStatus.Open)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                                            Abierto
                                        </span>
                                    }
                                    else if(item.Status == CycleStatus.Closed)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                                            Cerrado
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                                    @(item.Scope == "Category" ? $"Categoría (ID: {item.CategoryId})" : "Total")
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                                    @(item.User?.DisplayName ?? "Sistema")
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                                    @item.ClosedAt?.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if(item.Status == CycleStatus.Open)
                                    {
                                        <a asp-action="Counting" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-900 font-medium text-sm mr-3">Continuar Conteo</a>
                                    }
                                    else
                                    {
                                        <a asp-action="Details" asp-route-id="@item.Id" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white font-medium text-sm">Ver Detalle</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
