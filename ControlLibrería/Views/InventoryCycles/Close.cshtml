@model ControlLibrería.Models.Entities.InventoryCycle

@{
    ViewData["Title"] = "Cerrar Inventario";
    var totalDifferences = Model.Counts.Count(c => c.Difference != 0);
    var totalGain = Model.Counts.Where(c => c.Difference > 0).Sum(c => c.Difference);
    var totalLoss = Model.Counts.Where(c => c.Difference < 0).Sum(c => c.Difference);
    var netAdjustment = totalGain + totalLoss; // Quantity unit
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[1000px] mx-auto">
        <a asp-action="Counting" asp-route-id="@Model.Id" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Revisión y Cierre</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Verifica las diferencias antes de aplicar los ajustes.</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1000px] mx-auto">
        
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-orange-50 dark:bg-orange-900/20 rounded-2xl p-6 border border-orange-200 dark:border-orange-800">
                <p class="text-sm font-bold text-orange-900 dark:text-orange-400 mb-1">Productos con Diferencia</p>
                <div class="flex items-end gap-2">
                    <span class="text-3xl font-bold text-orange-900 dark:text-orange-400">@totalDifferences</span>
                    <span class="text-sm text-orange-700 dark:text-orange-500 mb-1">de @Model.Counts.Count</span>
                </div>
            </div>

             <div class="bg-red-50 dark:bg-red-900/20 rounded-2xl p-6 border border-red-200 dark:border-red-800">
                <p class="text-sm font-bold text-red-900 dark:text-red-400 mb-1">Faltantes (Unidades)</p>
                <span class="text-3xl font-bold text-red-900 dark:text-red-400">@totalLoss</span>
            </div>

             <div class="bg-green-50 dark:bg-green-900/20 rounded-2xl p-6 border border-green-200 dark:border-green-800">
                <p class="text-sm font-bold text-green-900 dark:text-green-400 mb-1">Sobrantes (Unidades)</p>
                <span class="text-3xl font-bold text-green-900 dark:text-green-400">+@totalGain</span>
            </div>
        </div>

        <!-- Discrepancy Table -->
        <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Detalle de Diferencias</h3>
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase">Producto</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Sistema</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Físico</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Diferencia</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var item in Model.Counts.Where(c => c.Difference != 0).OrderBy(c => c.Difference))
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-bold text-gray-900 dark:text-white">@item.Product.Name</div>
                                    <div class="text-xs text-gray-500">@item.Product.Barcode</div>
                                </td>
                                <td class="px-6 py-4 text-center text-sm text-gray-600 dark:text-gray-300">@item.SystemQuantityAtClose</td>
                                <td class="px-6 py-4 text-center text-sm font-bold text-blue-600">@item.PhysicalQuantity</td>
                                <td class="px-6 py-4 text-center">
                                    @if(item.Difference < 0)
                                    {
                                        <span class="text-red-600 font-bold">@item.Difference</span>
                                    }
                                    else
                                    {
                                        <span class="text-green-600 font-bold">+@item.Difference</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if(!Model.Counts.Any(c => c.Difference != 0))
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                    <span class="material-symbols-outlined text-[48px] text-green-500 mb-2">thumb_up</span>
                                    <p>¡Excelente! Todo cuadra perfectamente.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Closing Form -->
        <div class="bg-red-50 dark:bg-red-900/10 rounded-3xl border border-red-100 dark:border-red-900/30 p-6">
            <h3 class="text-lg font-bold text-red-900 dark:text-red-400 mb-4">Confirmar Cierre y Ajuste</h3>
            <p class="text-sm text-red-800 dark:text-red-300 mb-6">
                Al confirmar, el sistema <strong>ajustará automáticamente</strong> el stock de los productos con diferencias para que coincida con el conteo físico. Esta acción quedará registrada en la bitácora.
            </p>

            <form asp-action="CloseConfirmed" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="mb-6">
                    <label class="block text-sm font-bold text-red-900 dark:text-red-400 mb-2">Notas de Cierre</label>
                    <textarea name="notes" rows="3" class="w-full rounded-xl bg-white dark:bg-gray-800 border-none px-4 py-3 text-sm focus:ring-2 focus:ring-red-500/20" placeholder="Observaciones finales..."></textarea>
                </div>

                <div class="flex justify-end gap-3">
                    <a asp-action="Counting" asp-route-id="@Model.Id" class="bg-white text-gray-700 font-bold py-3 px-8 rounded-xl border border-gray-200 hover:bg-gray-50 transition-all">
                        Seguir Contando
                    </a>
                    <button type="submit" class="bg-red-600 text-white font-bold py-3 px-8 rounded-xl shadow-xl shadow-red-500/30 hover:bg-red-700 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                         <span class="material-symbols-outlined text-[20px]">lock_reset</span>
                        Confirmar y Ajustar Stock
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
