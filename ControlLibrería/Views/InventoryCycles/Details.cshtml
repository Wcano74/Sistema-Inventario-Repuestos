@model ControlLibrería.Models.Entities.InventoryCycle

@{
    ViewData["Title"] = "Detalle de Inventario";
     var totalDifferences = Model.Counts.Count(c => c.Difference != 0);
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[1000px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Inventario #@Model.Id (Cerrado)</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">
                Cerrado el @Model.ClosedAt?.ToString("dd/MM/yyyy HH:mm") por @(Model.User?.DisplayName ?? "Sistema")
            </p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1000px] mx-auto">
        
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm p-6 mb-8">
            <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Notas</h3>
            <p class="text-gray-600 dark:text-gray-300 italic">"@(string.IsNullOrEmpty(Model.Notes) ? "Sin notas" : Model.Notes)"</p>
        </div>

        <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Resultados del Arqueo</h3>
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase">Producto</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Sistema</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Físico</th>
                            <th class="px-6 py-4 text-center text-xs font-bold text-gray-500 uppercase">Ajuste</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var item in Model.Counts.Where(c => c.Difference != 0).OrderBy(c => c.Difference))
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-bold text-gray-900 dark:text-white">@item.Product.Name</div>
                                    <div class="text-xs text-gray-500">@item.Product.Barcode</div>
                                </td>
                                <td class="px-6 py-4 text-center text-sm text-gray-600 dark:text-gray-300">@item.SystemQuantityAtClose</td>
                                <td class="px-6 py-4 text-center text-sm font-bold text-blue-600">@item.PhysicalQuantity</td>
                                <td class="px-6 py-4 text-center">
                                    @if(item.Difference < 0)
                                    {
                                        <span class="text-red-600 font-bold">@item.Difference</span>
                                    }
                                    else
                                    {
                                        <span class="text-green-600 font-bold">+@item.Difference</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
