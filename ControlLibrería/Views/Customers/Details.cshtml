@model ControlLibrería.Models.ViewModels.CustomerDetailsViewModel
@{
    ViewData["Title"] = "Detalles del Cliente";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[1200px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="flex-1">
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">@Model.Customer.Name</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Información completa del cliente</p>
        </div>
        <div class="flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Customer.Id" class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 hover:bg-blue-600">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Editar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Customer Info Card -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm p-6">
                <div class="flex items-center justify-center mb-6">
                    <div class="flex h-20 w-20 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                        <span class="material-symbols-outlined text-[40px]">person</span>
                    </div>
                </div>
                
                <h3 class="text-lg font-bold text-center text-[#111418] dark:text-white mb-6">@Model.Customer.Name</h3>
                
                <div class="space-y-4">
                    <div>
                        <p class="text-xs font-bold text-gray-400 uppercase mb-1">NIT/DPI</p>
                        <p class="text-sm text-[#111418] dark:text-white">@(Model.Customer.NitDpi ?? "N/A")</p>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Customer.Phone))
                    {
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Teléfono</p>
                            <div class="flex items-center gap-2">
                                <p class="text-sm text-[#111418] dark:text-white">@Model.Customer.Phone</p>
                                <a href="https://wa.me/@(Model.Customer.Phone.Replace(" ", "").Replace("-", "").Replace("+", ""))" target="_blank" class="text-green-500 hover:text-green-600">
                                    <svg class="size-4 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.44-9.889 9.888-.001 2.224.58 3.276 1.697 5.17l-.953 3.486 3.745-.96zm13.111-5.111c-.328-.164-1.942-.958-2.241-1.069-.3-.109-.519-.164-.738.164-.219.328-.847 1.069-1.039 1.287-.192.219-.383.246-.711.082s-1.383-.51-2.635-1.627c-.973-.867-1.631-1.939-1.822-2.267-.192-.328-.02-.505.145-.668.148-.146.328-.383.493-.574.164-.192.219-.328.328-.547.11-.219.055-.41-.028-.574-.082-.164-.738-1.777-1.011-2.434-.267-.641-.539-.553-.738-.563-.192-.01-.41-.011-.629-.011s-.574.082-.875.41c-.301.328-1.148 1.121-1.148 2.733s1.175 3.17 1.339 3.389c.164.219 2.313 3.532 5.603 4.956.782.339 1.393.541 1.87.693.785.249 1.5.214 2.066.129.631-.095 1.942-.793 2.216-1.558.274-.765.274-1.422.192-1.558-.083-.136-.301-.218-.629-.382z"/></svg>
                                </a>
                            </div>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.Customer.Email))
                    {
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Email</p>
                            <p class="text-sm text-[#111418] dark:text-white">@Model.Customer.Email</p>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.Customer.Address))
                    {
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Dirección</p>
                            <p class="text-sm text-[#111418] dark:text-white">@Model.Customer.Address</p>
                        </div>
                    }
                    
                    <div class="pt-4 border-t border-gray-100 dark:border-gray-800">
                        <p class="text-xs font-bold text-gray-400 uppercase mb-1">Fecha de Registro</p>
                        <p class="text-sm text-[#111418] dark:text-white">@Model.Customer.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats and History -->
        <div class="lg:col-span-2 space-y-6">
            
            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                    <div class="flex items-center gap-3">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600 dark:bg-green-900/30">
                            <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase">Total Comprado</p>
                            <p class="text-xl font-bold text-[#111418] dark:text-white">Q @Model.TotalPurchased.ToString("N2")</p>
                        </div>
                    </div>
                </div>
                
                <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                    <div class="flex items-center gap-3">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/30">
                            <span class="material-symbols-outlined text-[24px]">receipt_long</span>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase">Transacciones</p>
                            <p class="text-xl font-bold text-[#111418] dark:text-white">@Model.TotalTransactions</p>
                        </div>
                    </div>
                </div>
                
                <div class="bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-800 p-4">
                    <div class="flex items-center gap-3">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-100 text-purple-600 dark:bg-purple-900/30">
                            <span class="material-symbols-outlined text-[24px]">calendar_today</span>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 uppercase">Última Compra</p>
                            <p class="text-sm font-bold text-[#111418] dark:text-white">
                                @if (Model.LastPurchaseDate.HasValue)
                                {
                                    @Model.LastPurchaseDate.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-gray-400">Sin compras</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Purchase History -->
            <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white">Historial de Compras</h3>
                    <p class="text-xs text-gray-500 mt-1">Últimas 20 transacciones</p>
                </div>
                
                @if (Model.RecentSales.Any())
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                                <tr>
                                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha</th>
                                    <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Productos</th>
                                    <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Total</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                                @foreach (var sale in Model.RecentSales)
                                {
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                                        <td class="px-6 py-4 text-sm text-[#111418] dark:text-white">
                                            @sale.Date.ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                        <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                                            @sale.SaleDetails.Count item(s)
                                        </td>
                                        <td class="px-6 py-4 text-right text-sm font-bold text-[#111418] dark:text-white">
                                            Q @sale.Total.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-12 text-center">
                        <div class="flex justify-center mb-4">
                            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800">
                                <span class="material-symbols-outlined text-[32px] text-gray-400">shopping_cart</span>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500">Este cliente aún no ha realizado compras</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
