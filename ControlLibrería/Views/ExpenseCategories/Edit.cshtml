@model ControlLibrería.Models.Entities.ExpenseCategory
@{
    ViewData["Title"] = "Editar Categoría de Gasto";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[800px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Editar Categoría</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Modifica los detalles de la categoría de gasto</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[800px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <form asp-action="Edit" class="p-8 space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                <input type="hidden" asp-for="Id" />

                <div>
                    <label asp-for="Name" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2"></label>
                    <input asp-for="Name" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2"></label>
                    <textarea asp-for="Description" rows="4" class="w-full rounded-xl bg-gray-50 dark:bg-gray-800 border-none p-4 text-sm focus:ring-2 focus:ring-primary/20"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-gray-50 dark:border-gray-800">
                    <a asp-action="Index" class="px-6 py-3 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all">Cancelar</a>
                    <button type="submit" class="bg-primary text-white font-bold py-3 px-8 rounded-xl shadow-lg shadow-blue-500/20 hover:bg-blue-600 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">save</span>
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
