@using SistemaInventario.Services
@using SistemaInventario.Models.Entities
@using Microsoft.AspNetCore.Identity
@inject IConfigurationService ConfigService
@inject UserManager<ApplicationUser> UserManager
@{
    var storeName = await ConfigService.GetConfigurationAsync("NombreNegocio", "Sistema de Inventario");
    var currentUser = await UserManager.GetUserAsync(User);
}
<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @storeName</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@@100..700,0..1&display=swap" rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#137fec",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        @@layer base {
            body { @("@")apply overflow-hidden; }
        }
        .main-content::-webkit-scrollbar { width: 6px; }
        .main-content::-webkit-scrollbar-thumb { background: #dbe0e6; border-radius: 10px; }
        .dark .main-content::-webkit-scrollbar-thumb { background: #374151; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#111418] dark:text-white">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar -->
        <aside class="flex w-64 flex-col border-r border-[#dbe0e6] dark:border-gray-800 bg-white dark:bg-[#1a2632] h-full shrink-0 z-20 transition-all">
            <div class="flex h-full flex-col justify-between p-4">
                <div class="flex flex-col gap-6">
                    <!-- User Profile / Brand -->
                    <div class="flex gap-3 items-center px-2">
                        <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 shadow-sm border border-gray-100 dark:border-gray-700 flex items-center justify-center bg-blue-100 text-blue-600 font-bold" 
                             style='@(currentUser?.ProfilePictureUrl != null ? $"background-image: url(\"{currentUser.ProfilePictureUrl}\")" : "")'>
                            @if (currentUser?.ProfilePictureUrl == null) {
                                @(currentUser?.FirstName?.Substring(0, 1) ?? "U")
                            }
                        </div>
                        <div class="flex flex-col">
                            <h1 class="text-[#111418] dark:text-white text-sm font-bold leading-none truncate max-w-[140px]">@(currentUser?.DisplayName ?? "Cajero")</h1>
                            <p class="text-[#617589] dark:text-gray-400 text-[10px] font-bold uppercase tracking-wider mt-1">
                                @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Bodeguero") ? "Bodeguero" : "Vendedor") • ID: @(currentUser?.EmployeeCode ?? "00000")
                            </p>
                        </div>
                    </div>
                    <!-- Navigation Links -->
                    <nav class="flex flex-col gap-1">
                        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                            <span class="material-symbols-outlined text-[24px]">dashboard</span>
                            <span class="text-sm font-semibold">Dashboard</span>
                        </a>
                        <a asp-controller="Products" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(new[] { "Products", "Categories", "Suppliers" }.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                            <span class="material-symbols-outlined text-[24px]">inventory_2</span>
                            <span class="text-sm font-medium">Inventario</span>
                        </a>
                        <div class="ml-9 flex flex-col gap-1 mb-2">
                            <a asp-controller="Categories" asp-action="Index" class="text-xs px-2 py-1.5 rounded-md @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "text-primary font-bold" : "text-[#617589] hover:text-[#111418] dark:hover:text-white") transition-colors">Categorías</a>
                            <a asp-controller="Suppliers" asp-action="Index" class="text-xs px-2 py-1.5 rounded-md @(ViewContext.RouteData.Values["controller"]?.ToString() == "Suppliers" ? "text-primary font-bold" : "text-[#617589] hover:text-[#111418] dark:hover:text-white") transition-colors">Proveedores</a>
                            <a asp-controller="PurchaseOrders" asp-action="Index" class="text-xs px-2 py-1.5 rounded-md @(ViewContext.RouteData.Values["controller"]?.ToString() == "PurchaseOrders" ? "text-primary font-bold" : "text-[#617589] hover:text-[#111418] dark:hover:text-white") transition-colors">Pedidos</a>
                        </div>
                        @if (!User.IsInRole("Bodeguero"))
                        {
                            <a asp-controller="Sales" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sales" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">shopping_cart</span>
                                <span class="text-sm font-medium">Ventas</span>
                            </a>
                        }
                        @if (!User.IsInRole("Bodeguero") && (User.IsInRole("Admin") || (currentUser != null && currentUser.CanProcessRefunds)))
                        {
                            <a href="/devoluciones" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "SaleRefunds" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">keyboard_return</span>
                                <span class="text-sm font-medium">Devoluciones</span>
                            </a>
                        }
                        @if (!User.IsInRole("Bodeguero"))
                        {
                            <a asp-controller="Customers" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">group</span>
                                <span class="text-sm font-medium">Clientes</span>
                            </a>
                            <a asp-controller="CashRegister" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "CashRegister" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">payments</span>
                                <span class="text-sm font-medium">Caja</span>
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Expenses" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(new[] { "Expenses", "ExpenseCategories" }.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">receipt_long</span>
                                <span class="text-sm font-medium">Egresos</span>
                            </a>
                            <a asp-controller="Reports" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">bar_chart</span>
                                <span class="text-sm font-medium">Reportes</span>
                            </a>
                            <a asp-controller="Settings" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">settings</span>
                                <span class="text-sm font-medium">Configuración</span>
                            </a>
                            <a asp-controller="Settings" asp-action="Users" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">admin_panel_settings</span>
                                <span class="text-sm font-medium">Usuarios</span>
                            </a>
                        }
                        
                         <!-- Inventory Cycles -->
                         @if (User.IsInRole("Admin") || User.IsInRole("Bodeguero") || (await ConfigService.GetConfigurationAsync("Permissions_CanManageInventory", "false") == "true"))
                         {
                            <a asp-controller="InventoryCycles" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg @(ViewContext.RouteData.Values["controller"]?.ToString() == "InventoryCycles" ? "bg-primary/10 text-primary dark:text-blue-400" : "text-[#617589] dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800") transition-colors group">
                                <span class="material-symbols-outlined text-[24px]">fact_check</span>
                                <span class="text-sm font-medium">Auditoría Inventario</span>
                            </a>
                         }
                    </nav>
                </div>
                <!-- Bottom Action -->
                <div class="px-2">
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        <button type="submit" class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-[#617589] dark:text-gray-400 hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-600 dark:hover:text-red-400 transition-colors">
                            <span class="material-symbols-outlined text-[24px]">logout</span>
                            <span class="text-sm font-medium">Cerrar Sesión</span>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-light dark:bg-background-dark relative">
            <div class="flex-1 overflow-y-auto main-content scroll-smooth">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        var isError = TempData["Error"] != null;
        <div id="toast" class="fixed bottom-6 right-6 @(isError ? "bg-red-600 shadow-red-500/20" : "bg-green-600 shadow-green-500/20") text-white px-6 py-3 rounded-2xl shadow-2xl flex items-center gap-3 animate-bounce z-[100]">
            <span class="material-symbols-outlined">@(isError ? "report" : "check_circle")</span>
            <span class="text-sm font-bold">@(TempData["Success"] ?? TempData["Error"])</span>
        </div>
    }
    <script>
        // Global Toast Function
        window.showToast = function(message, type = 'success') {
            const isError = type === 'error';
            const colorClass = isError ? 'bg-red-600 shadow-red-500/20' : 'bg-green-600 shadow-green-500/20';
            const icon = isError ? 'report' : 'check_circle';
            
            const toastHtml = `
                <div class="fixed bottom-6 right-6 ${colorClass} text-white px-6 py-3 rounded-2xl shadow-2xl flex items-center gap-3 animate-bounce z-[100] toast-enter">
                    <span class="material-symbols-outlined">${icon}</span>
                    <span class="text-sm font-bold">${message}</span>
                </div>
            `;
            
            const toastContainer = document.createElement('div');
            toastContainer.innerHTML = toastHtml;
            const toastElement = toastContainer.firstElementChild;
            document.body.appendChild(toastElement);

            setTimeout(() => {
                toastElement.remove();
            }, 4000);
        };

        // Auto-remove server-side toasts
        const serverToast = document.getElementById('toast');
        if (serverToast) {
            setTimeout(() => serverToast.remove(), 4000);
        }
    </script>
</body>
</html>