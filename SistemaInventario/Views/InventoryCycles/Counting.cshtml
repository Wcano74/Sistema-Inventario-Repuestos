@model SistemaInventario.Models.Entities.InventoryCycle

@{
    ViewData["Title"] = "Realizar Conteo";
    bool blindCount = ViewBag.BlindCount ?? false;
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center justify-between max-w-[1200px] mx-auto">
        <div class="flex items-center gap-4">
             <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Conteo de Existencias</h2>
                <div class="flex items-center gap-2 text-sm text-[#617589]">
                    <span>Ciclo #@Model.Id</span>
                    <span>•</span>
                    <span>@Model.Counts.Count productos</span>
                    @if(blindCount)
                    {
                         <span class="px-2 py-0.5 rounded bg-purple-100 text-purple-700 text-xs font-bold">Modo Ciego Activo</span>
                    }
                </div>
            </div>
        </div>
        <div class="flex gap-3">
             <a asp-action="PrintSheet" asp-route-id="@Model.Id" target="_blank" class="bg-blue-100 text-blue-700 font-bold py-2 px-4 rounded-xl hover:bg-blue-200 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined">print</span>
                <span>Imprimir Hoja</span>
            </a>
             <a asp-action="Close" asp-route-id="@Model.Id" class="bg-green-600 text-white font-bold py-2 px-6 rounded-xl shadow-lg shadow-green-500/30 hover:bg-green-700 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined">check_circle</span>
                <span>Finalizar y Revisar</span>
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[1200px] mx-auto">
        
        <!-- Search/Filter Placeholder -->
        <input type="text" id="searchInput" placeholder="Buscar producto por nombre o código..." class="w-full max-w-md mb-6 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#1a2632] focus:ring-2 focus:ring-blue-500/20" />

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="productsGrid">
            @foreach (var count in Model.Counts.OrderBy(c => c.Product.Name))
            {
                <div class="product-card bg-white dark:bg-[#1a2632] rounded-2xl border @(count.IsVerified ? "border-green-500 border-2" : "border-[#dbe0e6] dark:border-gray-800") shadow-sm p-4 relative transition-all" data-name="@count.Product.Name" data-barcode="@count.Product.Barcode">
                   
                    @if(count.IsVerified)
                    {
                        <div class="absolute top-2 right-2 text-green-500">
                            <span class="material-symbols-outlined">check_circle</span>
                        </div>
                    }

                    <h3 class="font-bold text-[#111418] dark:text-white mb-1 truncate" title="@count.Product.Name">@count.Product.Name</h3>
                    <p class="text-xs text-gray-500 mb-4">@count.Product.Barcode</p>

                    <div class="flex items-end justify-between gap-4">
                        <div class="flex-1">
                             @if(!blindCount)
                            {
                                <p class="text-xs text-gray-400 mb-1">Sistema: @count.Product.StockQuantity</p>
                            }
                            else
                            {
                                 <p class="text-xs text-transparent select-none bg-gray-100 dark:bg-gray-800 rounded px-1 mb-1 w-fit">Hidden</p>
                            }
                        </div>
                        
                        <div class="flex-1">
                             <label class="block text-xs font-bold text-blue-600 mb-1">Conteo Físico</label>
                             <input type="number" 
                                    value="@count.PhysicalQuantity" 
                                    class="count-input w-full h-10 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 font-bold text-center focus:ring-2 focus:ring-blue-500/20"
                                    data-id="@count.Id" 
                                    onchange="updateCount(this)" />
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Search Filter
    document.getElementById('searchInput').addEventListener('keyup', function() {
        var filter = this.value.toLowerCase();
        var cards = document.getElementsByClassName('product-card');

        for (var i = 0; i < cards.length; i++) {
            var name = cards[i].getAttribute('data-name').toLowerCase();
            var barcode = cards[i].getAttribute('data-barcode').toLowerCase();
            
            if (name.includes(filter) || barcode.includes(filter)) {
                cards[i].style.display = "";
            } else {
                cards[i].style.display = "none";
            }
        }
    });

    // Update Count AJAX
    function updateCount(input) {
        var countId = input.getAttribute('data-id');
        var qty = input.value;
        var card = input.closest('.product-card');

        fetch('/InventoryCycles/UpdateCount', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'countId=' + countId + '&physicalQuantity=' + qty
        })
        .then(response => {
            if (response.ok) {
                // Visual feedback
                card.classList.remove('border-[#dbe0e6]', 'dark:border-gray-800');
                card.classList.add('border-green-500', 'border-2');
                
                // Add Check icon if not exists
                if(!card.querySelector('.absolute.top-2.right-2')) {
                    var icon = document.createElement('div');
                    icon.className = 'absolute top-2 right-2 text-green-500';
                    icon.innerHTML = '<span class="material-symbols-outlined">check_circle</span>';
                    card.appendChild(icon);
                }
            } else {
                alert('Error al guardar el conteo');
            }
        });
    }
</script>
