@model SistemaInventario.Models.Entities.InventoryCycle

@{
    ViewData["Title"] = "Abrir Inventario";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[800px] mx-auto">
         <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Nuevo Ciclo de Inventario</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Inicia una nueva toma física de inventario</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[800px] mx-auto bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm p-8">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
            
            <div class="mb-6">
                <label asp-for="Scope" class="block text-sm font-bold text-[#111418] dark:text-white mb-2">Alcance del Inventario</label>
                <select asp-for="Scope" id="ScopeSelect" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-blue-500/20">
                    <option value="Total">Inventario Total (Toda la tienda)</option>
                    <option value="Category">Por Categoría (Cíclico)</option>
                </select>
                <span asp-validation-for="Scope" class="text-red-500 text-xs"></span>
            </div>

            <div class="mb-6 hidden" id="CategoryContainer">
                <label asp-for="CategoryId" class="block text-sm font-bold text-[#111418] dark:text-white mb-2">Seleccionar Categoría</label>
                <select asp-for="CategoryId" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-blue-500/20" asp-items="ViewBag.CategoryId">
                    <option value="">-- Seleccione una Categoría --</option>
                </select>
                <p class="text-xs text-gray-500 mt-2">Solo se listarán productos de esta categoría para contar.</p>
            </div>

            <div class="mb-8">
                <label asp-for="Notes" class="block text-sm font-bold text-[#111418] dark:text-white mb-2">Notas de Apertura (Opcional)</label>
                <textarea asp-for="Notes" rows="3" class="w-full rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20" placeholder="Ej: Auditoría mensual regular..."></textarea>
                <span asp-validation-for="Notes" class="text-red-500 text-xs"></span>
            </div>

            <div class="flex items-center gap-4 p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-900/50 mb-8">
                <span class="material-symbols-outlined text-blue-600 dark:text-blue-400">info</span>
                <p class="text-sm text-blue-800 dark:text-blue-300">Al abrir el inventario, se generará una lista de conteo. El stock del sistema seguirá cambiando si realizas ventas mientras cuentas.</p>
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:-translate-y-0.5 transition-all">
                Iniciar Inventario
            </button>
        </form>
    </div>
</div>

<script>
    document.getElementById('ScopeSelect').addEventListener('change', function() {
        var categoryContainer = document.getElementById('CategoryContainer');
        if (this.value === 'Category') {
            categoryContainer.classList.remove('hidden');
        } else {
            categoryContainer.classList.add('hidden');
        }
    });
</script>
