@model SistemaInventario.Models.Entities.PurchaseOrder

@inject Microsoft.AspNetCore.Identity.UserManager<SistemaInventario.Models.Entities.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Detalle del Pedido #" + Model.Id;
    var currentUser = await UserManager.GetUserAsync(User);
    var canManage = User.IsInRole("Admin") || (currentUser != null && currentUser.CanManageOrders);
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Pedido #@Model.Id</h2>
            <div class="flex items-center gap-2 text-sm text-[#617589] dark:text-gray-400">
                <span>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                <span>•</span>
                <span>@(Model.Supplier?.Name ?? "Sin Proveedor")</span>
            </div>
        </div>
        <div class="flex items-center gap-3">
             <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Volver
            </a>
            <button onclick="window.print()" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">print</span>
                Imprimir
            </button>
            @if (Model.Supplier != null && !string.IsNullOrEmpty(Model.Supplier.Phone))
            {
                <a href="#" onclick="sendWhatsApp(event)" class="flex items-center justify-center gap-2 rounded-lg bg-green-500 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-green-500/20 hover:bg-green-600 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">chat</span>
                    WhatsApp
                </a>
            }
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[1400px] grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column: Order Info -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            <!-- Items Table -->
            <div class="rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632] overflow-hidden">
                <div class="px-6 py-4 border-b border-[#dbe0e6] dark:border-gray-800">
                    <h3 class="font-bold text-[#111418] dark:text-white">Productos Solicitados</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-[#111418] dark:text-white">
                         <thead class="bg-gray-50 text-xs uppercase text-[#617589] dark:bg-gray-800/50 dark:text-gray-400">
                            <tr>
                                <th class="px-4 py-3 font-medium">Producto</th>
                                <th class="px-4 py-3 font-medium text-center">Cantidad</th>
                                <th class="px-4 py-3 font-medium text-right">Costo Unit.</th>
                                <th class="px-4 py-3 font-medium text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#dbe0e6] dark:divide-gray-800">
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="px-4 py-3">
                                        <p class="font-medium">@item.Product?.Name</p>
                                        <p class="text-xs text-[#617589] dark:text-gray-400">@item.Product?.Barcode</p>
                                    </td>
                                    <td class="px-4 py-3 text-center">@item.Quantity</td>
                                    <td class="px-4 py-3 text-right">@item.UnitCost.ToString("C")</td>
                                    <td class="px-4 py-3 text-right font-medium">@item.TotalCost.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-gray-50 dark:bg-gray-800/50 border-t border-[#dbe0e6] dark:border-gray-800">
                            <tr>
                                <th colspan="3" class="px-4 py-3 text-right font-bold">Total del Pedido:</th>
                                <th class="px-4 py-3 text-right font-bold text-primary text-lg">@Model.TotalAmount.ToString("C")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            
             <!-- Notes -->
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="rounded-xl border border-[#dbe0e6] bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                    <h3 class="font-bold text-[#111418] dark:text-white mb-2">Notas</h3>
                    <p class="text-sm text-[#617589] dark:text-gray-400">@Model.Notes</p>
                </div>
            }
        </div>

        <!-- Right Column: Status & Actions -->
        <div class="flex flex-col gap-6">
            <div class="rounded-xl border border-[#dbe0e6] bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                <h3 class="font-bold text-[#111418] dark:text-white mb-4">Estado del Pedido</h3>
                
                <div class="flex items-center gap-3 mb-6">
                     @if (Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Pending)
                    {
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
                            <span class="material-symbols-outlined">pending</span>
                        </div>
                        <div>
                            <p class="font-bold text-[#111418] dark:text-white">Pendiente</p>
                            <p class="text-xs text-[#617589] dark:text-gray-400">Esperando recepción</p>
                        </div>
                    }
                    else if (Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Received)
                    {
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
                            <span class="material-symbols-outlined">check_circle</span>
                        </div>
                         <div>
                            <p class="font-bold text-[#111418] dark:text-white">Recibido</p>
                            <p class="text-xs text-[#617589] dark:text-gray-400">Inventario actualizado</p>
                        </div>
                    }
                    else
                    {
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400">
                            <span class="material-symbols-outlined">cancel</span>
                        </div>
                        <div>
                            <p class="font-bold text-[#111418] dark:text-white">Cancelado</p>
                            <p class="text-xs text-[#617589] dark:text-gray-400">El pedido fue anulado</p>
                        </div>
                    }
                </div>

                <div class="space-y-3 pt-4 border-t border-[#dbe0e6] dark:border-gray-800">
                    @if (Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Pending && canManage)
                    {
                        <div class="rounded-lg bg-blue-50 p-3 text-xs text-blue-800 dark:bg-blue-900/20 dark:text-blue-300 mb-4">
                            <p class="font-medium mb-1">Nota importante:</p>
                            <p>Al marcar como recibido, el stock de los productos aumentará automáticamente.</p>
                        </div>

                        <form asp-action="Receive" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('¿Confirma la recepción de la mercadería?');">
                            <button type="submit" class="w-full flex items-center justify-center gap-2 rounded-lg bg-green-600 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-green-700 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">inventory</span>
                                Recibir Mercadería
                            </button>
                        </form>
                        
                        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('¿Seguro que desea cancelar este pedido?');">
                            <button type="submit" class="w-full flex items-center justify-center gap-2 rounded-lg border border-red-200 bg-red-50 py-2.5 text-sm font-bold text-red-600 hover:bg-red-100 dark:border-red-900/50 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/30 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">block</span>
                                Cancelar Pedido
                            </button>
                        </form>
                    }
                    @if (!canManage && Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Pending)
                    {
                        <div class="rounded-lg bg-gray-50 p-4 text-center text-sm text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                            <p>No tienes permisos para gestionar este pedido.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="rounded-xl border border-[#dbe0e6] bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                <h3 class="font-bold text-[#111418] dark:text-white mb-4">Detalles Adicionales</h3>
                <dl class="space-y-4 text-sm">
                    <div class="flex justify-between">
                        <dt class="text-[#617589] dark:text-gray-400">Fecha Esperada</dt>
                        <dd class="font-medium text-[#111418] dark:text-white">@(Model.ExpectedDate?.ToString("dd/MM/yyyy") ?? "-")</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-[#617589] dark:text-gray-400">Creado por</dt>
                        <dd class="font-medium text-[#111418] dark:text-white">@(Model.CreatedByUser?.DisplayName ?? "Sistema")</dd>
                    </div>
                    @if (Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Received)
                    {
                        <div class="flex justify-between">
                            <dt class="text-[#617589] dark:text-gray-400">Recibido por</dt>
                            <dd class="font-medium text-[#111418] dark:text-white">@(Model.ReceivedByUser?.DisplayName ?? "-")</dd>
                        </div>
                    }
                    @if (Model.Status == SistemaInventario.Models.Entities.PurchaseOrderStatus.Canceled)
                    {
                        <div class="flex justify-between">
                            <dt class="text-[#617589] dark:text-gray-400">Cancelado por</dt>
                            <dd class="font-medium text-[#111418] dark:text-white">@(Model.CanceledByUser?.DisplayName ?? "-")</dd>
                        </div>
                    }
                </dl>
            </div>
        </div>
</div>

<script>
    function sendWhatsApp(e) {
        e.preventDefault();
        
        var phone = '@(Model.Supplier?.Phone?.Replace(" ", "") ?? "")';
        // Ensure country code - assume 502 if not present but this is a rough heuristic
        if (!phone.startsWith('502') && phone.length === 8) phone = '502' + phone;

        var message = `*PEDIDO #${@Model.Id} - @Model.OrderDate.ToString("dd/MM/yyyy")*\n`;
        message += `Proveed: *${'@(Model.Supplier?.Name)'}*\n`;
        message += `--------------------------------\n`;

        @foreach (var item in Model.Items)
        {
            <text>
            message += `▪ ${'@item.Product?.Barcode'} - ${'@item.Product?.Name'} (x${@item.Quantity})\n`;
            </text>
        }
        
        message += `--------------------------------\n`;
        message += `Total Estimado: *${'@Model.TotalAmount.ToString("C")'}*\n\n`;
        message += `_${'@(string.IsNullOrEmpty(Model.Notes) ? "" : "Nota: " + Model.Notes)'}_`;

        var url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
        window.open(url, '_blank');
    }
</script>
</div>
