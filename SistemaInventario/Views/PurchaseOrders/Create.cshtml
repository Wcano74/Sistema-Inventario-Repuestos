@model SistemaInventario.Models.Entities.PurchaseOrder

@{
    ViewData["Title"] = "Crear Pedido";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Nuevo Pedido</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Crea una nueva orden de compra</p>
        </div>
        <div class="flex items-center gap-3">
             <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                Cancelar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[1400px]">
        <form asp-action="Create" id="orderForm" class="flex flex-col gap-6" onsubmit="return validateOrder()">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
            
            <!-- Main Info Card -->
            <div class="rounded-xl border border-[#dbe0e6] bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Información General</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label asp-for="SupplierId" class="text-sm font-medium text-[#111418] dark:text-white"></label>
                        <select asp-for="SupplierId" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" asp-items="ViewBag.SupplierId" id="SupplierId">
                            <option value="">-- Seleccione Proveedor --</option>
                        </select>
                        <span asp-validation-for="SupplierId" class="text-xs text-red-500"></span>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label asp-for="ExpectedDate" class="text-sm font-medium text-[#111418] dark:text-white"></label>
                        <input asp-for="ExpectedDate" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" type="date" />
                        <span asp-validation-for="ExpectedDate" class="text-xs text-red-500"></span>
                    </div>
                    <div class="flex flex-col gap-2 md:col-span-2">
                        <label asp-for="Notes" class="text-sm font-medium text-[#111418] dark:text-white"></label>
                        <textarea asp-for="Notes" class="w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] p-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <!-- Products Card -->
            <div class="rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
                 <div class="flex items-center justify-between border-b border-[#dbe0e6] px-6 py-4 dark:border-gray-800">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white">Productos</h3>
                    <button type="button" class="flex items-center gap-2 text-sm font-medium text-yellow-600 hover:text-yellow-700 dark:text-yellow-500" id="btnLoadLowStock">
                        <span class="material-symbols-outlined text-[20px]">warning</span>
                        Cargar Stock Bajo
                    </button>
                </div>
                
                <div class="p-6">
                     <!-- Add Item Form -->
                    <div class="flex flex-col md:flex-row gap-4 items-end mb-6 bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg">
                        <div class="flex-1 w-full">
                            <label class="text-xs font-medium text-[#617589] dark:text-gray-400 mb-1 block">Producto</label>
                            <select id="productSelect" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-white px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-700 dark:bg-gray-800 dark:text-white">
                                <option value="">-- Seleccione Producto --</option>
                            </select>
                            <select id="allProductsSource" style="display:none;" asp-items="ViewBag.ProductId"></select>
                        </div>
                        <div class="w-32">
                             <label class="text-xs font-medium text-[#617589] dark:text-gray-400 mb-1 block">Cantidad</label>
                             <input type="number" id="newQty" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-white px-3 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-700 dark:bg-gray-800 dark:text-white" value="1" min="1" />
                        </div>
                        <div class="w-auto">
                            <button type="button" class="h-10 px-6 rounded-lg bg-primary text-white text-sm font-medium hover:bg-blue-600 transition-colors w-full md:w-auto" id="btnAddProduct">
                                Agregar
                            </button>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="overflow-x-auto rounded-lg border border-[#dbe0e6] dark:border-gray-800">
                        <table class="w-full text-left text-sm" id="itemsTable">
                            <thead class="bg-gray-50 text-xs uppercase text-[#617589] dark:bg-gray-800/50 dark:text-gray-400">
                                <tr>
                                    <th class="px-4 py-3 font-medium">Producto</th>
                                    <th class="px-4 py-3 font-medium w-32">Cantidad</th>
                                    <th class="px-4 py-3 font-medium w-40 text-right">Costo (Est.)</th>
                                    <th class="px-4 py-3 font-medium w-40 text-right">Subtotal</th>
                                    <th class="px-4 py-3 font-medium w-16"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-[#dbe0e6] dark:divide-gray-800 bg-white dark:bg-[#1a2632] text-[#111418] dark:text-white">
                                <!-- Items here -->
                            </tbody>
                            <tfoot class="bg-gray-50 dark:bg-gray-800/50 border-t border-[#dbe0e6] dark:border-gray-800">
                                <tr>
                                    <th colspan="3" class="px-4 py-3 text-right font-bold text-[#111418] dark:text-white">Total Estimado:</th>
                                    <th class="px-4 py-3 text-right font-bold text-primary" id="grandTotal">Q0.00</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4">
                 <a asp-action="Index" class="h-11 px-6 flex items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="h-11 px-8 rounded-lg bg-primary text-white text-sm font-bold shadow-lg shadow-blue-500/20 hover:bg-blue-600 transition-colors">
                    Crear Pedido
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            // Clone options
            var $source = $('#allProductsSource option').clone();
            $('#productSelect').append($source);

            $('#btnAddProduct').click(function () {
                var pid = $('#productSelect').val();
                var pname = $('#productSelect option:selected').text();
                var qty = $('#newQty').val();
                
                if (!pid) { showToast('Seleccione un producto', 'error'); return; }
                if (qty <= 0) { showToast('Cantidad inválida', 'error'); return; }
                
                $.get('/pedidos/api/products?id=' + pid, function(data) {
                    var product = data.find(p => p.id == pid);
                    var cost = product ? product.cost : 0;
                    addProductRow(pid, pname, qty, cost);
                    $('#productSelect').val('');
                    $('#newQty').val(1);
                });
            });

            function addProductRow(pid, pname, qty, cost) {
                var rowId = 'row_' + pid;
                if ($('#' + rowId).length > 0) {
                    showToast('El producto ya está en la lista', 'error');
                   return;
                }

                var subtotal = (qty * cost).toFixed(2);
                
                var html = `
                    <tr id="${rowId}" class="group hover:bg-gray-50 dark:hover:bg-gray-800/50">
                        <td class="px-4 py-3">
                            <span class="font-medium">${pname}</span>
                            <input type="hidden" name="productIds" value="${pid}" />
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="quantities" value="${qty}" class="qty-input h-8 w-full rounded border border-[#dbe0e6] px-2 text-sm focus:border-primary focus:outline-none dark:border-gray-700 dark:bg-gray-800" min="1" onchange="updateTotals()" />
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="costs" value="${cost}" class="cost-input h-8 w-full rounded border border-[#dbe0e6] px-2 text-sm text-right focus:border-primary focus:outline-none dark:border-gray-700 dark:bg-gray-800" step="0.01" onchange="updateTotals()" />
                        </td>
                        <td class="px-4 py-3 text-right font-medium subtotal">Q${subtotal}</td>
                        <td class="px-4 py-3 text-center">
                            <button type="button" class="text-red-500 hover:text-red-700 transition-colors" onclick="removeRow('${rowId}')">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </td>
                    </tr>
                `;
                $('#itemsTable tbody').append(html);
                updateTotals();
            }
            
            window.removeRow = function(id) {
                $('#' + id).remove();
                updateTotals();
            }

            window.updateTotals = function() {
                var total = 0;
                $('#itemsTable tbody tr').each(function() {
                    var qty = parseFloat($(this).find('.qty-input').val()) || 0;
                    var cost = parseFloat($(this).find('.cost-input').val()) || 0;
                    var sub = qty * cost;
                    $(this).find('.subtotal').text('Q' + sub.toFixed(2));
                    total += sub;
                });
                $('#grandTotal').text('Q' + total.toFixed(2));
            }

            $('#btnLoadLowStock').click(function() {
                var supplierId = $('#SupplierId').val();
                var url = '/pedidos/api/products';
                if(supplierId) url += '?supplierId=' + supplierId;

                $.get(url, function(data) {
                    var addedCount = 0;
                    data.forEach(function(p) {
                        if (p.stock < p.minStock) {
                            var suggestQty = (p.minStock - p.stock) + 5;
                            if(suggestQty < 5) suggestQty = 5;

                            if ($('#row_' + p.id).length === 0) {
                                addProductRow(p.id, p.name, suggestQty, p.cost);
                                addedCount++;
                            }
                        }
                    });
                     if(addedCount === 0) showToast('No se encontraron productos adicionales con stock bajo.', 'error');
                     else showToast('Productos con stock bajo agregados.', 'success');
                });
            });

            window.validateOrder = function() {
                var rowCount = $('#itemsTable tbody tr').length;
                if (rowCount === 0) {
                    showToast('Debes agregar al menos un producto al pedido', 'error');
                    return false;
                }
                return true;
            }
        });
    </script>
}
