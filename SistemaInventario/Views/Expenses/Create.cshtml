@model SistemaInventario.Models.Entities.Expense
@{
    ViewData["Title"] = "Registrar Egreso";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[800px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Registrar Egreso</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Ingresa una nueva salida de dinero o gasto operativo</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[800px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <form asp-action="Create" class="p-8 space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Date" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2"></label>
                        <input asp-for="Date" type="datetime-local" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                        <span asp-validation-for="Date" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="ExpenseCategoryId" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2">Categoría</label>
                        <select asp-for="ExpenseCategoryId" asp-items="ViewBag.ExpenseCategoryId" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20">
                            <option value="">Seleccione una categoría...</option>
                        </select>
                        <span asp-validation-for="ExpenseCategoryId" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2"></label>
                    <input asp-for="Description" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" placeholder="Ej: Pago de recibo de luz de Diciembre" />
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Amount" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2"></label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
                            <input asp-for="Amount" type="number" step="0.01" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none pl-8 pr-4 text-sm font-bold focus:ring-2 focus:ring-primary/20" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="Reference" class="block text-sm font-bold text-[#111418] dark:text-gray-300 mb-2">Referencia / No. Recibo</label>
                        <input asp-for="Reference" class="w-full h-12 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" placeholder="Ej: REC-12345" />
                        <span asp-validation-for="Reference" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-gray-50 dark:border-gray-800">
                    <a asp-action="Index" class="px-6 py-3 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all">Cancelar</a>
                    <button type="submit" class="bg-red-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg shadow-red-500/20 hover:bg-red-700 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined">save</span>
                        Registrar Gasto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
