@model SistemaInventario.Models.ViewModels.ProductDetailsViewModel
@inject SistemaInventario.Services.IConfigurationService Config
@{
    ViewData["Title"] = "Detalles del Producto";
    var product = Model.Product;
    var symbol = await Config.GetCurrencySymbolAsync();
}

<div class="px-4 md:px-10 lg:px-20 xl:px-32 flex flex-1 justify-center py-5">
    <div class="layout-content-container flex flex-col max-w-[1200px] flex-1">
        <!-- Breadcrumbs -->
        <div class="flex flex-wrap gap-2 p-4 pb-0">
            <a asp-action="Index" class="text-[#617589] text-sm font-medium leading-normal hover:text-primary transition-colors">Inventario</a>
            <span class="text-[#617589] text-sm font-medium leading-normal">/</span>
            <span class="text-[#617589] text-sm font-medium leading-normal">@(product.Category?.Name ?? "Sin Categoría")</span>
            <span class="text-[#617589] text-sm font-medium leading-normal">/</span>
            <span class="text-[#111418] dark:text-white text-sm font-medium leading-normal">Detalles del Producto</span>
        </div>

        <!-- Page Heading -->
        <div class="flex flex-wrap justify-between items-start gap-4 p-4">
            <div class="flex min-w-72 flex-col gap-2">
                <h1 class="text-[#111418] dark:text-white text-3xl md:text-4xl font-black leading-tight tracking-[-0.033em]">@product.Name</h1>
                <div class="flex flex-wrap items-center gap-3 text-[#617589] dark:text-gray-400 text-sm md:text-base font-normal">
                    @if(product.IsActive)
                    {
                        <span class="flex items-center gap-1 text-green-600 font-medium bg-green-50 dark:bg-green-900/20 px-2 py-1 rounded">
                            <span class="material-symbols-outlined text-[16px]">check_circle</span> Activo
                        </span>
                    }
                    else
                    {
                        <span class="flex items-center gap-1 text-red-600 font-medium bg-red-50 dark:bg-red-900/20 px-2 py-1 rounded">
                            <span class="material-symbols-outlined text-[16px]">cancel</span> Inactivo
                        </span>
                    }
                </div>
            </div>
            <div class="flex gap-3">
                @if (false)
                {
                    <button onclick="window.print()" class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-white dark:bg-gray-800 border border-[#dbe0e6] dark:border-gray-700 text-[#111418] dark:text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-[#f8fafc] dark:hover:bg-gray-700 transition-colors">
                        <span class="material-symbols-outlined text-[20px] mr-2">print</span>
                        <span class="truncate">Etiqueta</span>
                    </button>
                }
                @if (ViewBag.CanEditStock == true)
                {
                    <a asp-action="Edit" asp-route-id="@product.Id" class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-blue-600 transition-colors shadow-sm">
                        <span class="material-symbols-outlined text-[20px] mr-2">edit</span>
                        <span class="truncate">Editar Producto</span>
                    </a>
                }
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 px-4 py-6">
            <div class="flex flex-1 gap-3 rounded-xl border border-[#e5e7eb] dark:border-gray-800 bg-white dark:bg-[#1a2632] p-4 items-center shadow-sm">
                <div class="flex items-center justify-center size-12 rounded-full bg-blue-50 dark:bg-blue-900/20 text-primary">
                    <span class="material-symbols-outlined">inventory_2</span>
                </div>
                <div class="flex flex-col">
                    <p class="text-[#617589] dark:text-gray-400 text-sm font-medium">Stock Actual</p>
                    <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">@product.StockQuantity <span class="text-sm font-normal text-[#617589]">u.</span></h2>
                </div>
            </div>
            <div class="flex flex-1 gap-3 rounded-xl border border-[#e5e7eb] dark:border-gray-800 bg-white dark:bg-[#1a2632] p-4 items-center shadow-sm">
                <div class="flex items-center justify-center size-12 rounded-full @(product.StockQuantity <= product.MinStock ? "bg-red-50 text-red-600" : "bg-orange-50 text-orange-600")">
                    <span class="material-symbols-outlined">warning</span>
                </div>
                <div class="flex flex-col">
                    <p class="text-[#617589] dark:text-gray-400 text-sm font-medium">Stock Mínimo</p>
                    <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">@product.MinStock <span class="text-sm font-normal text-[#617589]">u.</span></h2>
                </div>
            </div>
            <div class="flex flex-1 gap-3 rounded-xl border border-[#e5e7eb] dark:border-gray-800 bg-white dark:bg-[#1a2632] p-4 items-center shadow-sm">
                <div class="flex items-center justify-center size-12 rounded-full bg-green-50 dark:bg-green-900/20 text-green-600">
                    <span class="material-symbols-outlined">sell</span>
                </div>
                <div class="flex flex-col">
                    <p class="text-[#617589] dark:text-gray-400 text-sm font-medium">Precio Venta</p>
                    <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">@symbol@product.Price.ToString("N2")</h2>
                </div>
            </div>
            @if (ViewBag.SeeCostPrice == true)
            {
                @if (!User.IsInRole("Bodeguero"))
                {
                    <div class="flex flex-1 gap-3 rounded-xl border border-[#e5e7eb] dark:border-gray-800 bg-white dark:bg-[#1a2632] p-4 items-center shadow-sm">
                        <div class="flex items-center justify-center size-12 rounded-full bg-purple-50 dark:bg-purple-900/20 text-purple-600">
                            <span class="material-symbols-outlined">attach_money</span>
                        </div>
                  
                        <div class="flex flex-col">
                            <p class="text-[#617589] dark:text-gray-400 text-sm font-medium">Costo Unitario</p>
                            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">@symbol@product.Cost.ToString("N2")</h2>
                        </div>
                    
                    </div>
                }
            }
        </div>

        <!-- Navigation Placeholder (Tabs Styling) -->
        <div class="px-4">
            <div class="flex border-b border-[#dbe0e6] dark:border-gray-800 gap-8 overflow-x-auto no-scrollbar">
                <button onclick="switchTab('details')" id="tab-details" class="flex flex-col items-center justify-center border-b-[3px] border-b-primary text-primary pb-[13px] pt-4 px-2 transition-colors">
                    <p class="text-sm font-bold leading-normal tracking-[0.015em] whitespace-nowrap">Información General</p>
                </button>
                <button onclick="switchTab('history')" id="tab-history" class="flex flex-col items-center justify-center border-b-[3px] border-b-transparent text-[#617589] pb-[13px] pt-4 px-2 hover:text-[#111418] dark:hover:text-white transition-colors">
                    <p class="text-sm font-bold leading-normal tracking-[0.015em] whitespace-nowrap">Historial de Stock</p>
                </button>
            </div>
        </div>

        <!-- Main Content Split Pane -->
        <div id="content-details" class="flex flex-col lg:flex-row gap-6 p-4 pt-6">
            <!-- Left Column: Details -->
            <div class="flex-1 flex flex-col gap-6">
                <!-- Basic Info Card -->
                <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 p-6 shadow-sm">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-gray-400">info</span>
                        Datos Principales
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Nombre del Producto</label>
                            <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">@product.Name</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Marca / Fabricante</label>
                            <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">@(product.Brand ?? "Genérico / No especificado")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Categoría</label>
                            <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">@(product.Category?.Name ?? "Sin Categoría")</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Código de Barras</label>
                            <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent font-mono">@(product.Barcode ?? "Sin Código")</p>
                        </div>
                        <div class="flex flex-col gap-1 md:col-span-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Descripción</label>
                            <p class="text-base font-normal text-[#111418] dark:text-gray-300 bg-[#f8fafc] dark:bg-gray-800/50 p-3 rounded border border-transparent leading-relaxed">
                                @(string.IsNullOrEmpty(product.Description) ? "Sin descripción disponible para este producto." : product.Description)
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Location Card -->
                <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 p-6 shadow-sm">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-gray-400">location_on</span>
                        Ubicación en Almacén
                    </h3>
                    @if (product.WarehouseLocation != null && product.WarehouseLocation.WarehouseRack != null)
                    {
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Bodega</label>
                                <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">@(product.WarehouseLocation.WarehouseRack.Warehouse?.Name ?? "—")</p>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Estante</label>
                                <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">@product.WarehouseLocation.WarehouseRack.Name</p>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Fila</label>
                                <p class="text-base font-medium text-[#111418] dark:text-white bg-[#f8fafc] dark:bg-gray-800/50 p-2.5 rounded border border-transparent">F@(product.WarehouseLocation.Row)</p>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Código</label>
                                <div class="flex items-center gap-2">
                                    <span class="inline-flex items-center gap-1 rounded-lg bg-blue-50 dark:bg-blue-900/20 px-3 py-2 text-sm font-bold text-primary dark:text-blue-400">
                                        <span class="material-symbols-outlined text-[16px]">pin_drop</span>
                                        @product.WarehouseLocation.LocationCode
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-3 text-[#617589] dark:text-gray-400 bg-[#f8fafc] dark:bg-gray-800/50 p-4 rounded-lg">
                            <span class="material-symbols-outlined text-[24px]">location_off</span>
                            <p class="text-sm">Sin ubicación asignada. Puede asignar una ubicación al <a asp-action="Edit" asp-route-id="@product.Id" class="text-primary hover:underline font-semibold">editar el producto</a>.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Visuals & Supplier -->
            <div class="w-full lg:w-[360px] flex flex-col gap-6">
                <!-- Image Card -->
                <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 p-4 shadow-sm flex flex-col gap-4">
                    <div class="w-full bg-[#f6f7f8] dark:bg-gray-800 rounded-lg overflow-hidden relative group @(!string.IsNullOrEmpty(product.ImageUrl) ? "cursor-pointer" : "")" @(!string.IsNullOrEmpty(product.ImageUrl) ? "onclick=\"openLightbox()\"" : "")>
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/product-placeholder.svg" : product.ImageUrl)"
                             class="w-full max-h-[320px] object-contain p-2"
                             alt="@product.Name"
                             onerror="this.onerror=null;this.src='/images/product-placeholder.svg';this.closest('[onclick]')?.removeAttribute('onclick')" />
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
                                <div class="bg-black/50 rounded-full p-2">
                                    <span class="material-symbols-outlined text-white text-3xl">zoom_in</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Lightbox Modal -->
                @if (!string.IsNullOrEmpty(product.ImageUrl))
                {
                    <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm" onclick="closeLightbox(event)">
                        <button onclick="closeLightbox(event)" class="absolute top-4 right-4 z-10 bg-white/10 hover:bg-white/20 rounded-full p-2 transition-colors">
                            <span class="material-symbols-outlined text-white text-3xl">close</span>
                        </button>
                        <img src="@product.ImageUrl" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg shadow-2xl" alt="@product.Name" />
                    </div>
                }
                <!-- Supplier Quick View -->
                <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 p-6 shadow-sm">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white mb-4">Proveedor Principal</h3>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="size-12 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-primary dark:text-blue-400 font-bold text-xl uppercase">
                            @((product.Supplier?.Name ?? "?")[0])
                        </div>
                        <div>
                            <p class="font-bold text-[#111418] dark:text-white">@(product.Supplier?.Name ?? "No asignado")</p>
                            <p class="text-sm text-[#617589] dark:text-gray-400">ID: PROV-@(product.SupplierId ?? 0)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Movements Section (Hidden by default) -->
        <div id="content-history" class="px-4 pb-10 hidden">
            <div class="mt-6 bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 shadow-sm overflow-hidden">
                <div class="flex items-center justify-between p-6 border-b border-[#e5e7eb] dark:border-gray-800">
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white">Movimientos Recientes</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[#f8fafc] dark:bg-gray-800/50">
                                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha</th>
                                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-400">Tipo</th>
                                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-400">Cantidad</th>
                                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-400">Ref.</th>
                                <th class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-400">Usuario</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#e5e7eb] dark:divide-gray-800">
                            @if (!Model.RecentMovements.Any())
                            {
                                <tr>
                                    <td colspan="5" class="px-6 py-8 text-center text-[#617589] dark:text-gray-400 italic">No hay movimientos registrados para este producto.</td>
                                </tr>
                            }
                            @foreach (var movement in Model.RecentMovements)
                            {
                                <tr class="hover:bg-[#f8fafc] dark:hover:bg-gray-800/30 transition-colors">
                                    <td class="px-6 py-4 text-sm text-[#111418] dark:text-gray-300">@movement.Date.ToString("dd MMM yyyy, HH:mm")</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1 rounded-full px-2 py-1 text-xs font-semibold @(movement.Quantity < 0 ? "bg-red-50 text-red-600 dark:bg-red-900/20" : "bg-green-50 text-green-600 dark:bg-green-900/20")">
                                            <span class="material-symbols-outlined text-[14px]">@(movement.Quantity < 0 ? "arrow_downward" : "arrow_upward")</span>
                                            @movement.Type
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-sm font-bold @(movement.Quantity < 0 ? "text-red-500" : "text-green-500")">
                                        @(movement.Quantity > 0 ? "+" : "")@movement.Quantity
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">@movement.Reference</td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">@movement.User</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tab) {
            // content
            const detailsContent = document.getElementById('content-details');
            const historyContent = document.getElementById('content-history');
            
            // tabs
            const detailsTab = document.getElementById('tab-details');
            const historyTab = document.getElementById('tab-history');

            if (tab === 'details') {
                detailsContent.classList.remove('hidden');
                historyContent.classList.add('hidden');

                detailsTab.classList.add('border-b-primary', 'text-primary');
                detailsTab.classList.remove('border-b-transparent', 'text-[#617589]');
                
                historyTab.classList.remove('border-b-primary', 'text-primary');
                historyTab.classList.add('border-b-transparent', 'text-[#617589]');
            } else {
                detailsContent.classList.add('hidden');
                historyContent.classList.remove('hidden');

                historyTab.classList.add('border-b-primary', 'text-primary');
                historyTab.classList.remove('border-b-transparent', 'text-[#617589]');

                detailsTab.classList.remove('border-b-primary', 'text-primary');
                detailsTab.classList.add('border-b-transparent', 'text-[#617589]');
            }
        }

        function openLightbox() {
            const lb = document.getElementById('lightbox');
            if (lb) {
                lb.classList.remove('hidden');
                lb.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }
        }

        function closeLightbox(e) {
            if (e.target === document.getElementById('lightbox') || e.currentTarget.tagName === 'BUTTON') {
                const lb = document.getElementById('lightbox');
                lb.classList.add('hidden');
                lb.classList.remove('flex');
                document.body.style.overflow = '';
            }
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const lb = document.getElementById('lightbox');
                if (lb && !lb.classList.contains('hidden')) {
                    lb.classList.add('hidden');
                    lb.classList.remove('flex');
                    document.body.style.overflow = '';
                }
            }
        });
    </script>
}
