@model SistemaInventario.Models.ViewModels.ProductIndexViewModel
@inject SistemaInventario.Services.IConfigurationService Config
@{
    var symbol = await Config.GetCurrencySymbolAsync();
}

<div class="overflow-x-auto">
    <table class="w-full min-w-[800px] text-left">
        <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
            <tr>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Producto</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Marca</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">SKU</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Categoría</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Ubicación</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Stock</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Precio</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Estado</th>
                @if (ViewBag.WhatsAppAlertsEnabled == true && !string.IsNullOrEmpty(ViewBag.WhatsAppNumber as string))
                {
                    <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Alerta</th>
                }
                <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="@(ViewBag.WhatsAppAlertsEnabled == true ? 9 : 8)" class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center gap-2">
                            <span class="material-symbols-outlined text-gray-300 text-[48px]">inventory_2</span>
                            <p class="text-[#617589] dark:text-gray-400 font-medium">No se encontraron productos con estos filtros.</p>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Products)
            {
                <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors cursor-pointer @(item.IsActive ? "" : "opacity-60 grayscale")" onclick="window.location.href='@Url.Action("Details", "Products", new { id = item.Id })'"  >
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img class="h-full w-full object-cover" src="@item.ImageUrl" alt="@item.Name"/>
                                }
                                else
                                {
                                    <div class="flex h-full w-full items-center justify-center text-gray-400">
                                        <span class="material-symbols-outlined">image</span>
                                    </div>
                                }
                            </div>
                            <div class="flex flex-col">
                                <p class="text-sm font-medium text-[#111418] dark:text-white">@item.Name</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                        @(item.Brand ?? "-")
                    </td>
                    <td class="px-6 py-4 text-sm font-mono text-[#617589] dark:text-gray-400">
                        @(item.Barcode ?? "-")
                    </td>
                    <td class="px-6 py-4">
                        @if (item.Category != null)
                        {
                            <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                                @item.Category.Name
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4">
                        @if (item.WarehouseLocation != null && item.WarehouseLocation.WarehouseRack != null)
                        {
                            <span class="inline-flex items-center gap-1 rounded-md bg-blue-50 dark:bg-blue-900/20 px-2 py-1 text-xs font-bold text-primary dark:text-blue-400">
                                <span class="material-symbols-outlined text-[14px]">pin_drop</span>
                                @(item.WarehouseLocation.WarehouseRack.Warehouse?.Name) - @item.WarehouseLocation.LocationCode
                            </span>
                        }
                        else
                        {
                            <span class="text-sm text-[#617589] dark:text-gray-400">-</span>
                        }
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-bold @(item.StockQuantity <= item.MinStock ? "text-red-600 dark:text-red-400" : "text-[#111418] dark:text-white")">
                                @item.StockQuantity
                            </span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-sm font-bold text-[#111418] dark:text-white">
                        @symbol@item.Price.ToString("N2")
                    </td>
                    <td class="px-6 py-4">
                        @if (!item.IsActive)
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
                                Inactivo
                            </span>
                        }
                        else if (item.StockQuantity <= 0)
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800 dark:bg-red-900/30 dark:text-red-400">
                                <span class="h-1.5 w-1.5 rounded-full bg-red-600"></span> Agotado
                            </span>
                        }
                        else if (item.StockQuantity <= item.MinStock)
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-orange-100 px-2.5 py-0.5 text-xs font-medium text-orange-800 dark:bg-orange-900/30 dark:text-orange-400">
                                <span class="h-1.5 w-1.5 rounded-full bg-orange-500"></span> Bajo
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-400">
                                <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span> Disponible
                            </span>
                        }
                    </td>
                    @if (ViewBag.WhatsAppAlertsEnabled == true && !string.IsNullOrEmpty(ViewBag.WhatsAppNumber as string))
                    {
                        <td class="px-6 py-4" onclick="event.stopPropagation()">
                             @if (item.IsActive && item.StockQuantity <= item.MinStock)
                             {
                                <a href="https://wa.me/@(ViewBag.WhatsAppNumber.ToString().Replace(" ", "").Replace("-", "").Replace("+", ""))?text=Alerta: El producto '@item.Name' tiene solo @item.StockQuantity unidades restantes (Mínimo: @item.MinStock)" target="_blank" class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Enviar Alerta WhatsApp">
                                    <svg class="size-5 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.44-9.889 9.888-.001 2.224.58 3.276 1.697 5.17l-.953 3.486 3.745-.96zm13.111-5.111c-.328-.164-1.942-.958-2.241-1.069-.3-.109-.519-.164-.738.164-.219.328-.847 1.069-1.039 1.287-.192.219-.383.246-.711.082s-1.383-.51-2.635-1.627c-.973-.867-1.631-1.939-1.822-2.267-.192-.328-.02-.505.145-.668.148-.146.328-.383.493-.574.164-.192.219-.328.328-.547.11-.219.055-.41-.028-.574-.082-.164-.738-1.777-1.011-2.434-.267-.641-.539-.553-.738-.563-.192-.01-.41-.011-.629-.011s-.574.082-.875.41c-.301.328-1.148 1.121-1.148 2.733s1.175 3.17 1.339 3.389c.164.219 2.313 3.532 5.603 4.956.782.339 1.393.541 1.87.693.785.249 1.5.214 2.066.129.631-.095 1.942-.793 2.216-1.558.274-.765.274-1.422.192-1.558-.083-.136-.301-.218-.629-.382z"/></svg>
                                </a>
                             }
                        </td>
                    }
                    <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
                        <div class="flex items-center justify-end gap-2">
                            @if (ViewBag.CanAddToPOS == true && item.IsActive && item.StockQuantity > 0)
                            {
                                <button type="button" onclick="addToPOS(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))', @item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture), @item.StockQuantity, '@(item.ImageUrl ?? "")')" class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-white hover:bg-blue-600 transition-colors shadow-sm" title="Agregar al POS">
                                    <span class="material-symbols-outlined text-[18px]">add_shopping_cart</span>
                                </button>
                            }
                            <a asp-action="Details" asp-route-id="@item.Id" class="flex h-8 w-8 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#111418] hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 transition-colors" title="Ver Detalles y Bitácora">
                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                            </a>
                            @if (ViewBag.CanEditStock == true)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="flex h-8 w-8 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#111418] hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 transition-colors" title="Editar">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                
                                <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="flex h-8 w-8 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 transition-colors @(item.IsActive ? "text-red-500 hover:border-red-200 dark:text-red-400 dark:hover:bg-red-900/20" : "text-green-500 hover:border-green-200 dark:text-green-400 dark:hover:bg-green-900/20")" title="@(item.IsActive ? "Desactivar" : "Reactivar")">
                                        <span class="material-symbols-outlined text-[18px]">@(item.IsActive ? "power_settings_new" : "refresh")</span>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination Controls -->
@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between border-t border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
        <div class="flex flex-1 justify-between sm:hidden">
            @if (Model.HasPreviousPage)
            {
                <button onclick="changePage(@(Model.PageIndex - 1))" class="relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">Anterior</button>
            }
            else
            {
                <span class="relative inline-flex items-center rounded-md border border-transparent bg-gray-100 px-4 py-2 text-sm font-medium text-gray-400 dark:bg-gray-800 dark:text-gray-600 cursor-not-allowed">Anterior</span>
            }

            @if (Model.HasNextPage)
            {
                <button onclick="changePage(@(Model.PageIndex + 1))" class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">Siguiente</button>
            }
            else
            {
                <span class="relative ml-3 inline-flex items-center rounded-md border border-transparent bg-gray-100 px-4 py-2 text-sm font-medium text-gray-400 dark:bg-gray-800 dark:text-gray-600 cursor-not-allowed">Siguiente</span>
            }
        </div>
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-[#617589] dark:text-gray-400">
                    Mostrando página <span class="font-medium">@Model.PageIndex</span> de <span class="font-medium">@Model.TotalPages</span>
                </p>
            </div>
            <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                    <button onclick="changePage(@(Model.PageIndex - 1))" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 dark:ring-gray-700 dark:hover:bg-gray-800 @(!Model.HasPreviousPage ? "pointer-events-none opacity-50" : "")">
                        <span class="sr-only">Previous</span>
                        <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                    </button>
                    
                    @* Logic for page numbers window could go here, for now just simple Prev/Next *@
                    
                    <button onclick="changePage(@(Model.PageIndex + 1))" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 dark:ring-gray-700 dark:hover:bg-gray-800 @(!Model.HasNextPage ? "pointer-events-none opacity-50" : "")">
                        <span class="sr-only">Next</span>
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </button>
                </nav>
            </div>
        </div>
    </div>
}
