@using Microsoft.AspNetCore.Identity
@{
    Layout = null; // Basic layout for login
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Sistema de Inventario</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-[#0f172a] min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <!-- Logo/Header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center size-16 rounded-2xl bg-blue-600 text-white shadow-xl shadow-blue-500/20 mb-4">
                <span class="material-symbols-outlined text-[40px]">inventory_2</span>
            </div>
            <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Bienvenido</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-2">Ingresa tus credenciales para continuar</p>
        </div>

        <!-- Login Card -->
        <div class="bg-white dark:bg-[#1e293b] rounded-3xl shadow-2xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-800 p-8">
            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-900/30 rounded-xl p-4 flex gap-3">
                        <span class="material-symbols-outlined text-red-500 text-[20px]">error</span>
                        <div asp-validation-summary="All" class="text-sm text-red-600 dark:text-red-400 font-medium"></div>
                    </div>
                }

                <div>
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Código de Empleado (5 dígitos)</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">badge</span>
                        <input type="text" name="employeeCode" required maxlength="5" pattern="\d{5}"
                               class="w-full h-12 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl pl-12 pr-4 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none font-bold tracking-widest"
                               placeholder="12345" />
                    </div>
                </div>

                <div>
                    <div class="flex flex-wrap justify-between items-center mb-2">
                        <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Contraseña</label>
                    </div>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">lock</span>
                        <input type="password" name="password" required
                               class="w-full h-12 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl pl-12 pr-4 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none"
                               placeholder="••••••••" />
                    </div>
                </div>

                <div class="flex items-center">
                    <input type="checkbox" name="rememberMe" value="true" class="size-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                    <label class="ml-2 block text-sm text-slate-600 dark:text-slate-400">Recordarme en este equipo</label>
                </div>

                <button type="submit" class="w-full h-12 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 transition-all flex items-center justify-center gap-2">
                    Iniciar Sesión
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </button>
            </form>
        </div>

        <!-- Banner rama develop -->
        <div class="mt-6 bg-amber-500 text-white rounded-2xl px-5 py-3 flex items-center gap-3 shadow-lg shadow-amber-500/30">
            <span class="material-symbols-outlined text-[22px]">science</span>
            <div>
                <p class="font-bold text-sm">Entorno de desarrollo</p>
                <p class="text-amber-100 text-xs">Rama develop — pipeline Mac funcionando</p>
            </div>
        </div>

        <!-- Footer -->
        <p class="text-center text-slate-500 dark:text-slate-500 text-sm mt-6">
            &copy; 2026 Sistema de Inventario. Todos los derechos reservados.
        </p>
    </div>
</body>
</html>
