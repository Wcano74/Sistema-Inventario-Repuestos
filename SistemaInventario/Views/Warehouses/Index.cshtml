@model IEnumerable<SistemaInventario.Models.Entities.Warehouse>
@{
    ViewData["Title"] = "Gestión de Bodegas";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1200px] mx-auto">
        <div class="flex flex-col gap-1 w-full md:w-auto">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Bodegas</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Administra las bodegas principales de tu inventario</p>
        </div>
        <div class="flex items-center gap-4 flex-1 max-w-xl mx-auto md:mx-4 w-full md:w-auto">
            <form method="get" asp-action="Index" class="w-full relative flex items-center">
                <span class="material-symbols-outlined text-[#617589] dark:text-gray-400 absolute left-3">search</span>
                <input name="searchTerm" id="globalSearchInput" value="@ViewBag.SearchTerm" class="h-10 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] pl-10 pr-4 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Buscar estante, bodega o producto..." />
            </form>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto justify-end">
            <button type="button" onclick="openWarehouseModal()" class="flex items-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-sm font-bold text-white hover:bg-blue-600 transition-colors shadow-sm cursor-pointer whitespace-nowrap">
                <span class="material-symbols-outlined text-[20px]">add_business</span>
                Nueva Bodega
            </button>
        </div>
    </div>
</header>

<div class="px-6 py-6 pb-20 max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white dark:bg-[#1a2632] border border-[#dbe0e6] dark:border-gray-800 rounded-3xl p-6 shadow-sm flex flex-col gap-4">
                <div class="flex justify-between items-start">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 text-primary flex items-center justify-center">
                            <span class="material-symbols-outlined text-[24px]">warehouse</span>
                        </div>
                        <div>
                            <h3 class="text-[#111418] dark:text-white font-bold text-lg">@item.Name</h3>
                            <span class="inline-flex items-center gap-1 rounded bg-gray-100 dark:bg-gray-800 px-2 py-0.5 text-xs font-semibold text-gray-600 dark:text-gray-400">
                                @item.Racks.Count Estantes
                            </span>
                        </div>
                    </div>
                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="inline">
                        <button type="submit" class="w-10 h-6 flex items-center rounded-full p-1 transition-colors relative @(item.IsActive ? "bg-green-500" : "bg-gray-300 dark:bg-gray-700")">
                            <div class="w-4 h-4 rounded-full bg-white transition-transform @(item.IsActive ? "translate-x-4" : "translate-x-0") shadow-sm"></div>
                        </button>
                    </form>
                </div>
                
                <p class="text-sm text-[#617589] dark:text-gray-400 min-h-[20px] line-clamp-2 mb-2">
                    @(string.IsNullOrEmpty(item.Description) ? "Sin descripción general" : item.Description)
                </p>

                @if(item.Racks.Any())
                {
                    <div class="flex flex-col gap-2 max-h-[200px] overflow-y-auto pr-2 mb-2">
                        @foreach(var rack in item.Racks.OrderBy(r => r.Name))
                        {
                            <div class="flex items-center justify-between p-2.5 rounded-xl bg-gray-50 dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800 hover:border-blue-200 transition-colors">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-[#111418] dark:text-white">Estante @rack.Name</span>
                                    <span class="text-xs text-[#617589] dark:text-gray-400">@rack.NumberOfRows filas</span>
                                </div>
                                <div class="flex gap-2">
                                    <a asp-controller="Warehouse" asp-action="Edit" asp-route-id="@rack.Id" class="w-8 h-8 flex items-center justify-center rounded-lg text-[#617589] hover:bg-white dark:hover:bg-gray-700 hover:text-primary transition-colors shadow-sm">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex items-center justify-center p-6 rounded-xl bg-gray-50 dark:bg-gray-800/50 mb-2 border border-dashed border-gray-200 dark:border-gray-700">
                        <span class="text-sm text-[#617589] dark:text-gray-400">Sin estantes en esta bodega</span>
                    </div>
                }

                <div class="pt-4 mt-auto border-t border-[#f0f2f4] dark:border-gray-800 flex justify-between gap-2 flex-wrap items-center">
                    <a asp-controller="Warehouse" asp-action="Create" asp-route-warehouseId="@item.Id" class="h-9 px-3 flex items-center gap-1.5 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-sm font-bold text-primary hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors">
                        <span class="material-symbols-outlined text-[18px]">add</span>
                        Nuevo Estante
                    </a>
                    <div class="flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="h-9 px-3 flex items-center gap-1.5 rounded-lg border border-[#dbe0e6] dark:border-gray-700 text-sm font-semibold text-[#111418] dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="h-9 px-3 flex items-center gap-1.5 rounded-lg border border-red-100 bg-red-50 text-sm font-semibold text-red-600 hover:bg-red-100 transition-colors dark:border-red-900/30 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/40">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white dark:bg-[#1a2632] border border-[#dbe0e6] dark:border-gray-800 rounded-3xl p-12 text-center mt-6">
            <span class="material-symbols-outlined text-gray-300 text-6xl mb-4">domain_add</span>
            <h3 class="text-[#111418] dark:text-white text-xl font-bold mb-2">No hay bodegas registradas</h3>
            <p class="text-[#617589] dark:text-gray-400 mb-6">Comienza registrando la primera bodega de tu sistema.</p>
            <button type="button" onclick="openWarehouseModal()" class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-bold text-white hover:bg-blue-600 transition-colors cursor-pointer">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Crear Bodega
            </button>
        </div>
    }

    <!-- Detalle Completo de Estantes y Ubicaciones -->
    <div class="mt-12 pt-8 border-t border-[#dbe0e6] dark:border-gray-800">
        <div class="flex flex-col gap-1 mb-6">
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Detalle de Estantes y Ubicaciones</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Consulta el espacio ocupado y los productos almacenados en tus estantes</p>
        </div>

        <!-- Data Table Container -->
        <div id="rackTableContainer" class="mt-6 overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632] min-h-[200px] flex items-center justify-center">
            <span class="material-symbols-outlined animate-spin text-primary text-3xl">refresh</span>
        </div>
    </div>
</div>

<!-- Modal Nueva Bodega -->
<div id="newWarehouseModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity opacity-0">
    <div class="w-full max-w-lg rounded-2xl bg-white dark:bg-[#1a2632] shadow-2xl overflow-hidden transform scale-95 transition-transform" id="newWarehouseModalContent">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex justify-between items-center bg-gray-50/50 dark:bg-gray-800/30">
            <h3 class="text-lg font-bold text-[#111418] dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">add_business</span>
                Nueva Bodega
            </h3>
            <button type="button" onclick="closeWarehouseModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form action="/bodegas/crear" method="post" class="p-6 flex flex-col gap-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="IsActive" value="true" />
            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-semibold text-[#111418] dark:text-white">Nombre de la Bodega</label>
                <input type="text" name="Name" required class="h-12 rounded-xl border border-[#dbe0e6] bg-white px-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Ej. Bodega Central" />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-sm font-semibold text-[#111418] dark:text-white">Descripción (opcional)</label>
                <textarea name="Description" rows="2" class="rounded-xl border border-[#dbe0e6] bg-white p-4 text-sm focus:border-primary focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white" placeholder="Detalles sobre esta bodega..."></textarea>
            </div>

            <div class="pt-4 flex justify-end gap-3 border-t border-gray-100 dark:border-gray-800 mt-2">
                <button type="button" onclick="closeWarehouseModal()" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-[#dbe0e6] hover:bg-gray-50 rounded-xl dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700 dark:hover:bg-gray-700 transition-colors">Cancelar</button>
                <button type="submit" class="px-5 py-2.5 text-sm font-bold text-white bg-primary hover:bg-blue-600 rounded-xl shadow-sm transition-colors">Guardar Bodega</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openWarehouseModal() {
            const modal = document.getElementById('newWarehouseModal');
            const content = document.getElementById('newWarehouseModalContent');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        function closeWarehouseModal() {
            const modal = document.getElementById('newWarehouseModal');
            const content = document.getElementById('newWarehouseModalContent');
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 300);
        }

        const searchInput = document.getElementById('globalSearchInput');
        const tableContainer = document.getElementById('rackTableContainer');
        let searchTimeout;
        let currentPage = 1;

        function updateRacksTable(page = 1) {
            currentPage = page;
            const searchTerm = searchInput ? searchInput.value : '';
            const url = `/ubicaciones?searchTerm=${encodeURIComponent(searchTerm)}&page=${page}`;

            fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                tableContainer.innerHTML = html;
                tableContainer.classList.remove('flex', 'items-center', 'justify-center'); // remove loader classes
            });
        }

        window.changePage = function(page) {
            if (page < 1) return;
            updateRacksTable(page);
        }

        if (searchInput) {
            searchInput.addEventListener('input', () => {
                clearTimeout(searchTimeout);
                // We delay enough so that user can type before pushing a full Rack table AJAX reload.
                // Note that submitting the form via ENTER will reload the WHOLE page (Bodegas).
                searchTimeout = setTimeout(() => updateRacksTable(1), 300);
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateRacksTable(1);
        });
    </script>
}
