@model SistemaInventario.Models.ViewModels.WarehouseRackIndexViewModel

<div class="overflow-x-auto">
    <table class="w-full min-w-[700px] text-left">
        <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
            <tr>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Estante</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Bodega</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Descripción</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Filas</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Productos</th>
                <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Estado</th>
                <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
            @if (!Model.Racks.Any())
            {
                <tr>
                    <td colspan="7" class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center gap-2">
                            <span class="material-symbols-outlined text-gray-300 text-[48px]">shelves</span>
                            <p class="text-[#617589] dark:text-gray-400 font-medium">No se encontraron estantes.</p>
                            <p class="text-xs text-gray-400">Crea un estante para comenzar a organizar tu bodega.</p>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model.Racks)
            {
                var totalProducts = item.Locations.Sum(l => l.Products.Count);
                <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-[20px]">shelves</span>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-[#111418] dark:text-white">@item.Name</span>
                                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                                {
                                    var matchedLocs = item.Locations.Where(l => l.Products.Any(p => 
                                        p.Name.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase) || 
                                        p.Barcode.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                                        (p.Description != null && p.Description.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase))
                                    )).ToList();

                                    if (matchedLocs.Any())
                                    {
                                        <div class="mt-1">
                                            <span class="inline-flex items-center gap-1 rounded bg-green-50 dark:bg-green-900/20 px-2 py-0.5 text-[10px] font-bold text-green-700 dark:text-green-400">
                                                <span class="material-symbols-outlined text-[12px]">search_check</span>
                                                Producto en Fila(s): @string.Join(", ", matchedLocs.Select(l => l.Row))
                                            </span>
                                        </div>
                                    }
                                }
                                <!-- Visual de filas compacto -->
                                <div class="flex items-center gap-0.5 mt-1">
                                    @foreach (var loc in item.Locations.OrderBy(l => l.Row))
                                    {
                                        var hasProducts = loc.Products.Any();
                                        var isMatched = !string.IsNullOrWhiteSpace(Model.SearchTerm) && loc.Products.Any(p => 
                                            p.Name.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase) || 
                                            p.Barcode.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                                            (p.Description != null && p.Description.Contains(Model.SearchTerm, StringComparison.OrdinalIgnoreCase))
                                        );

                                        var blockClass = hasProducts ? (isMatched ? "bg-green-500 animate-pulse" : "bg-primary") : "bg-gray-200 dark:bg-gray-700";

                                        <div class="h-2 w-5 rounded-sm @blockClass" title="@item.Name-F@loc.Row: @loc.Products.Count producto(s)"></div>
                                    }
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm font-medium text-[#111418] dark:text-white">@(item.Warehouse?.Name ?? "—")</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-[#617589] dark:text-gray-400">@(item.Description ?? "—")</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded-md bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-xs font-bold">
                            @item.Locations.Count
                        </span>
                        <span class="text-xs text-[#617589] dark:text-gray-400">@(item.Locations.Count == 1 ? "fila" : "filas")</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded-md bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 text-xs font-bold">
                            @totalProducts
                        </span>
                        <span class="text-xs text-[#617589] dark:text-gray-400">@(totalProducts == 1 ? "producto" : "productos")</span>
                    </td>
                    <td class="px-6 py-4">
                        @if (item.IsActive)
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2.5 py-1 text-xs font-semibold text-green-700 dark:bg-green-900/20 dark:text-green-400">
                                <span class="size-1.5 rounded-full bg-green-500"></span> Activo
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 rounded-full bg-red-50 px-2.5 py-1 text-xs font-semibold text-red-700 dark:bg-red-900/20 dark:text-red-400">
                                <span class="size-1.5 rounded-full bg-red-500"></span> Inactivo
                            </span>
                        }
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-2 sm:opacity-0 transition-opacity group-hover:opacity-100">
                            @if (ViewBag.CanEditStock == true)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-[#617589] hover:border-primary hover:text-primary dark:border-gray-800 dark:bg-surface-dark transition-all" title="Editar">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#dbe0e6] bg-white text-red-400 hover:border-red-500 hover:text-red-500 dark:border-gray-800 dark:bg-surface-dark transition-all" title="Eliminar">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination Controls -->
@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between border-t border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
        <div class="flex flex-1 justify-between sm:hidden">
            @if (Model.HasPreviousPage)
            {
                <button onclick="changePage(@(Model.PageIndex - 1))" class="relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">Anterior</button>
            }
            else
            {
                <span class="relative inline-flex items-center rounded-md border border-transparent bg-gray-100 px-4 py-2 text-sm font-medium text-gray-400 dark:bg-gray-800 dark:text-gray-600 cursor-not-allowed">Anterior</span>
            }

            @if (Model.HasNextPage)
            {
                <button onclick="changePage(@(Model.PageIndex + 1))" class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">Siguiente</button>
            }
            else
            {
                <span class="relative ml-3 inline-flex items-center rounded-md border border-transparent bg-gray-100 px-4 py-2 text-sm font-medium text-gray-400 dark:bg-gray-800 dark:text-gray-600 cursor-not-allowed">Siguiente</span>
            }
        </div>
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-[#617589] dark:text-gray-400">
                    Mostrando página <span class="font-medium">@Model.PageIndex</span> de <span class="font-medium">@Model.TotalPages</span>
                </p>
            </div>
            <div>
                <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                    <button onclick="changePage(@(Model.PageIndex - 1))" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 dark:ring-gray-700 dark:hover:bg-gray-800 @(!Model.HasPreviousPage ? "pointer-events-none opacity-50" : "")">
                        <span class="sr-only">Previous</span>
                        <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                    </button>
                    <button onclick="changePage(@(Model.PageIndex + 1))" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 dark:ring-gray-700 dark:hover:bg-gray-800 @(!Model.HasNextPage ? "pointer-events-none opacity-50" : "")">
                        <span class="sr-only">Next</span>
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </button>
                </nav>
            </div>
        </div>
    </div>
}
