@model SistemaInventario.Models.ViewModels.WarehouseRackIndexViewModel
@{
    ViewData["Title"] = "Ubicaciones de Bodega";
}

<!-- Page Heading & Actions -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Ubicaciones de Bodega</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Gestiona estantes y filas para organizar tus productos</p>
        </div>
        <div class="flex items-center gap-3">
            @if (ViewBag.CanEditStock == true)
            {
                <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                    <span class="material-symbols-outlined text-[20px]">add</span>
                    Nuevo Estante
                </a>
            }
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        <!-- Search Toolbar -->
        <form method="get" asp-action="Index" class="flex flex-col gap-4 rounded-xl border border-[#dbe0e6] bg-white p-4 shadow-sm lg:flex-row lg:items-center lg:justify-between dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="relative flex w-full max-w-md items-center">
                <span class="material-symbols-outlined absolute left-3 text-[#617589] dark:text-gray-400">search</span>
                <input name="searchTerm" value="@Model.SearchTerm" class="h-11 w-full rounded-lg border border-[#dbe0e6] bg-[#f8f9fa] pl-10 pr-4 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-800 dark:bg-gray-800 dark:text-white dark:focus:border-blue-500" placeholder="Buscar por nombre o descripción..." type="text"/>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm text-[#617589] dark:text-gray-400">Total: <span class="font-bold text-[#111418] dark:text-white">@Model.TotalRacks</span> estantes</span>
                <div class="h-6 w-px bg-[#dbe0e6] dark:bg-gray-800 mx-1"></div>
                <button type="submit" class="flex h-9 items-center justify-center rounded-lg bg-primary/10 px-4 text-primary text-sm font-bold hover:bg-primary/20 transition-colors">
                    Filtrar
                </button>
            </div>
        </form>

        <!-- Data Table Container -->
        <div id="rackTableContainer" class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <partial name="_RackTablePartial" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.querySelector('input[name="searchTerm"]');
        const tableContainer = document.getElementById('rackTableContainer');
        let searchTimeout;
        let currentPage = 1;

        function updateTable(page = 1) {
            currentPage = page;
            const searchTerm = searchInput.value;
            const url = `@Url.Action("Index")?searchTerm=${encodeURIComponent(searchTerm)}&page=${page}`;

            fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                tableContainer.innerHTML = html;
            });
        }

        window.changePage = function(page) {
            if (page < 1) return;
            updateTable(page);
        }

        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => updateTable(1), 300);
        });
    </script>
}
