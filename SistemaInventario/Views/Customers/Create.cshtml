@model SistemaInventario.Models.Entities.Customer
@{
    ViewData["Title"] = "Nuevo Cliente";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[1200px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Nuevo Cliente</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Registra un nuevo cliente en el sistema</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[800px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <form asp-action="Create" method="post" class="p-8">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                
                <!-- Datos Personales -->
                <div class="mb-8">
                    <h3 class="text-xs font-bold text-primary uppercase tracking-widest mb-4">Datos Personales</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label asp-for="Name" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="Name" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" required />
                            <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="NitDpi" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="NitDpi" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="NitDpi" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="Phone" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="Phone" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="Phone" class="text-red-500 text-xs"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Email" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="Email" type="email" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Address" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="Address" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="Address" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                </div>

                <!-- Datos Fiscales -->
                <div class="mb-8 pt-6 border-t border-gray-100 dark:border-gray-800">
                    <h3 class="text-xs font-bold text-primary uppercase tracking-widest mb-4">Datos Fiscales (Opcional)</h3>
                    <div class="grid grid-cols-1 gap-4">
                        <div>
                            <label asp-for="FiscalName" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="FiscalName" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="FiscalName" class="text-red-500 text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="FiscalAddress" class="block text-[10px] font-bold text-gray-400 uppercase mb-1"></label>
                            <input asp-for="FiscalAddress" class="w-full h-11 rounded-xl bg-gray-50 dark:bg-gray-800 border-none px-4 text-sm focus:ring-2 focus:ring-primary/20" />
                            <span asp-validation-for="FiscalAddress" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex justify-end gap-3 pt-6">
                    <a asp-action="Index" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-3 px-8 rounded-xl hover:bg-gray-300 dark:hover:bg-gray-600 transition-all">
                        Cancelar
                    </a>
                    <button type="submit" class="bg-primary text-white font-bold py-3 px-8 rounded-xl shadow-xl shadow-primary/30 hover:bg-blue-600 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Guardar Cliente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
