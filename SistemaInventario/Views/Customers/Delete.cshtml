@model SistemaInventario.Models.Entities.Customer
@{
    ViewData["Title"] = "Eliminar Cliente";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex items-center gap-4 max-w-[800px] mx-auto">
        <a asp-action="Index" class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Eliminar Cliente</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm">Confirma la eliminación del cliente</p>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="max-w-[800px] mx-auto">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-red-200 dark:border-red-900/50 shadow-sm overflow-hidden">
            <div class="p-8">
                <div class="flex items-center gap-4 mb-6 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/50">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100 text-red-600 dark:bg-red-900/40">
                        <span class="material-symbols-outlined text-[28px]">warning</span>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-red-900 dark:text-red-400">¿Estás seguro de eliminar este cliente?</h3>
                        <p class="text-xs text-red-700 dark:text-red-500 mt-1">Esta acción no se puede deshacer</p>
                    </div>
                </div>

                <div class="space-y-4 mb-8">
                    <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50 dark:bg-gray-800/50">
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30">
                            <span class="material-symbols-outlined text-[24px]">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs text-gray-500 uppercase">Nombre</p>
                            <p class="text-sm font-bold text-[#111418] dark:text-white">@Model.Name</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.NitDpi))
                    {
                        <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50 dark:bg-gray-800/50">
                            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800">
                                <span class="material-symbols-outlined text-[24px]">badge</span>
                            </div>
                            <div class="flex-1">
                                <p class="text-xs text-gray-500 uppercase">NIT/DPI</p>
                                <p class="text-sm font-bold text-[#111418] dark:text-white">@Model.NitDpi</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="flex items-center gap-3 p-4 rounded-xl bg-gray-50 dark:bg-gray-800/50">
                            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800">
                                <span class="material-symbols-outlined text-[24px]">phone</span>
                            </div>
                            <div class="flex-1">
                                <p class="text-xs text-gray-500 uppercase">Teléfono</p>
                                <p class="text-sm font-bold text-[#111418] dark:text-white">@Model.Phone</p>
                            </div>
                        </div>
                    }
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="flex justify-end gap-3">
                        <a asp-action="Index" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-3 px-8 rounded-xl hover:bg-gray-300 dark:hover:bg-gray-600 transition-all">
                            Cancelar
                        </a>
                        <button type="submit" class="bg-red-600 text-white font-bold py-3 px-8 rounded-xl shadow-xl shadow-red-500/30 hover:bg-red-700 hover:-translate-y-0.5 transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-[20px]">delete</span>
                            Eliminar Cliente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
