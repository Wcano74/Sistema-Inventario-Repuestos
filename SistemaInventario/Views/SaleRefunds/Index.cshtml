@model List<SistemaInventario.Models.ViewModels.RefundIndexViewModel>

@{
    ViewData["Title"] = "Historial de Devoluciones";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Historial de Devoluciones</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Gestiona y revisa todas las notas de crédito emitidas</p>
        </div>
        <div class="flex items-center gap-3">
             <a asp-controller="Sales" asp-action="Index" class="flex items-center gap-2 rounded-lg bg-gray-100 dark:bg-gray-700 px-4 py-2 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                Ver Ventas
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-6">
        
        <!-- Filtros -->
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="p-6">
                <form method="get" class="flex flex-wrap items-end gap-4">
                    <div class="flex-1 min-w-[200px]">
                        <label class="mb-2 block text-sm font-bold text-[#111418] dark:text-white">Fecha Inicio</label>
                        <input type="date" name="startDate" class="w-full rounded-lg border border-[#dbe0e6] bg-white p-2.5 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-700 dark:bg-gray-900 dark:text-white" value="@ViewBag.StartDate">
                    </div>
                    <div class="flex-1 min-w-[200px]">
                        <label class="mb-2 block text-sm font-bold text-[#111418] dark:text-white">Fecha Fin</label>
                        <input type="date" name="endDate" class="w-full rounded-lg border border-[#dbe0e6] bg-white p-2.5 text-sm text-[#111418] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-700 dark:bg-gray-900 dark:text-white" value="@ViewBag.EndDate">
                    </div>
                    <button type="submit" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-blue-600 h-[42px]">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                        Filtrar
                    </button>
                </form>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="flex items-center gap-3 rounded-lg bg-red-50 p-4 text-red-700 dark:bg-red-900/20 dark:text-red-400 border border-red-100 dark:border-red-900/30">
                <span class="material-symbols-outlined">error</span>
                <p class="text-sm">@TempData["Error"]</p>
            </div>
        }

        <!-- Listado -->
        <div class="overflow-hidden rounded-xl border border-[#dbe0e6] bg-white shadow-sm dark:border-gray-800 dark:bg-[#1a2632]">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="border-b border-[#dbe0e6] bg-gray-50 dark:border-gray-800 dark:bg-gray-800/50">
                        <tr>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">ID</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Venta / Cliente</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Tipo</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Autorizado Por</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Motivo</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Monto</th>
                            <th class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4 font-mono text-xs text-[#617589] dark:text-gray-400">#@item.Id</td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-[#111418] dark:text-white">@item.RefundDate.ToString("dd/MM/yyyy")</span>
                                        <span class="text-xs text-[#617589] dark:text-gray-400">@item.RefundDate.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SaleId" class="text-sm font-bold text-primary hover:underline">Venta #@item.SaleId</a>
                                        <span class="text-xs text-[#617589] dark:text-gray-400">@item.CustomerName</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                     @if(item.RefundTypeName == "Total")
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-bold text-red-700 dark:bg-red-900/30 dark:text-red-400">
                                            Total
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-bold text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                                            Parcial
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm text-[#111418] dark:text-white">
                                    @item.UserName
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col gap-1">
                                        <span class="text-xs text-[#111418] dark:text-white truncate max-w-[200px]" title="@item.Reason">@item.Reason</span>
                                        @if(item.IsRegisteredAsExpense)
                                        {
                                            <span class="flex items-center gap-1 text-[10px] uppercase font-bold text-orange-600 dark:text-orange-400">
                                                <span class="material-symbols-outlined text-[14px]">payments</span> Egreso (Caja Cerrada)
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="text-sm font-bold text-red-600 dark:text-red-400">-Q @item.RefundAmount.ToString("N2")</span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gray-100 text-[#617589] hover:bg-primary hover:text-white transition-all dark:bg-gray-800 dark:text-gray-400" title="Ver Detalles">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 px-6 text-center">
                    <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-400">
                        <span class="material-symbols-outlined text-[40px]">inventory_2</span>
                    </div>
                    <h3 class="text-lg font-bold text-[#111418] dark:text-white">No se encontraron registros</h3>
                    <p class="mt-1 text-sm text-[#617589] dark:text-gray-400 text-pretty max-w-[300px]">No hay devoluciones para mostrar en el rango de fechas seleccionado.</p>
                </div>
            }
        </div>
    </div>
</div>

