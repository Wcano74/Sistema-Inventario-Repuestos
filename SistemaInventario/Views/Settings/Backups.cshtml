@model List<SistemaInventario.Models.ViewModels.BackupFileViewModel>

@{
    ViewData["Title"] = "Respaldos";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Respaldos de Base de Datos</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Gestiona copias de seguridad del sistema</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="flex items-center gap-2 rounded-lg bg-gray-100 dark:bg-gray-700 px-4 py-2 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Configuraci&oacute;n
            </a>
            <div class="flex gap-2">
                <form asp-action="CreateBackup" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                        <span class="material-symbols-outlined text-[20px]">database</span>
                        Respaldar BD
                    </button>
                </form>
                <form asp-action="CreateImageBackup" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="flex items-center gap-2 rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-green-500/20 transition-colors hover:bg-green-700">
                        <span class="material-symbols-outlined text-[20px]">image</span>
                        Respaldar Im&aacute;genes
                    </button>
                </form>
            </div>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1000px] flex-col gap-8">

        <!-- Info Card -->
        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl border border-blue-200 dark:border-blue-800 p-4 flex items-start gap-3">
            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 mt-0.5">info</span>
            <div class="text-sm text-blue-800 dark:text-blue-300">
                <p class="font-medium mb-1">Gesti&oacute;n de Respaldos</p>
                <p>Ahora puede respaldar tanto la **Base de Datos** como las **Im&aacute;genes** de los productos. Se recomienda realizar ambos respaldos antes de cualquier cambio importante o traslado de servidor.</p>
            </div>
        </div>

        @{
            var dbBackups = Model.Where(b => b.Type == SistemaInventario.Models.ViewModels.BackupType.Database).ToList();
            var imgBackups = Model.Where(b => b.Type == SistemaInventario.Models.ViewModels.BackupType.Images).ToList();
        }

        <!-- Database Backups List -->
        <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">database</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Respaldos de Base de Datos</h3>
                </div>
                <span class="text-xs text-gray-500 dark:text-gray-400">@dbBackups.Count respaldo(s)</span>
            </div>

            @if (!dbBackups.Any())
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-gray-300 dark:text-gray-600 text-[56px]">cloud_off</span>
                    <p class="mt-3 text-[#617589] dark:text-gray-400 font-medium">No hay respaldos de base de datos</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-[#dbe0e6] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/20">
                            <tr>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Archivo</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Tama&ntilde;o</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                            @foreach (var backup in dbBackups)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">
                                                <span class="material-symbols-outlined text-[20px]">database</span>
                                            </div>
                                            <span class="text-sm font-medium text-[#111418] dark:text-white font-mono">@backup.FileName</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                                        @backup.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center rounded-md bg-gray-100 dark:bg-gray-800 px-2 py-1 text-xs font-medium text-gray-600 dark:text-gray-400">
                                            @backup.SizeFormatted
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <button type="button" onclick="openRestoreModal('@backup.FileName', '@backup.CreatedAt.ToString("dd/MM/yyyy HH:mm")', 'database')" class="flex h-8 items-center gap-1.5 rounded-lg border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-900/20 px-3 text-xs font-medium text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors" title="Restaurar base de datos">
                                                <span class="material-symbols-outlined text-[16px]">restore</span>
                                                Restaurar
                                            </button>
                                            <button type="button" onclick="openDeleteModal('@backup.FileName')" class="flex h-8 w-8 items-center justify-center rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors" title="Eliminar">
                                                <span class="material-symbols-outlined text-[16px]">delete</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Image Backups List -->
        <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#e5e7eb] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-green-600">image</span>
                    <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Respaldos de Im&aacute;genes</h3>
                </div>
                <span class="text-xs text-gray-500 dark:text-gray-400">@imgBackups.Count respaldo(s)</span>
            </div>

            @if (!imgBackups.Any())
            {
                <div class="p-12 text-center">
                    <span class="material-symbols-outlined text-gray-300 dark:text-gray-600 text-[56px]">folder_off</span>
                    <p class="mt-3 text-[#617589] dark:text-gray-400 font-medium">No hay respaldos de im&aacute;genes</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-[#dbe0e6] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/20">
                            <tr>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Archivo</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Fecha</th>
                                <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Tama&ntilde;o</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-[#617589] dark:text-gray-400">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                            @foreach (var backup in imgBackups)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-50 dark:bg-green-900/30 text-green-600 dark:text-green-400">
                                                <span class="material-symbols-outlined text-[20px]">folder_zip</span>
                                            </div>
                                            <span class="text-sm font-medium text-[#111418] dark:text-white font-mono">@backup.FileName</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-[#617589] dark:text-gray-400">
                                        @backup.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center rounded-md bg-gray-100 dark:bg-gray-800 px-2 py-1 text-xs font-medium text-gray-600 dark:text-gray-400">
                                            @backup.SizeFormatted
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <button type="button" onclick="openRestoreModal('@backup.FileName', '@backup.CreatedAt.ToString("dd/MM/yyyy HH:mm")', 'images')" class="flex h-8 items-center gap-1.5 rounded-lg border border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-900/20 px-3 text-xs font-medium text-green-700 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-900/40 transition-colors" title="Restaurar imágenes">
                                                <span class="material-symbols-outlined text-[16px]">restore</span>
                                                Restaurar
                                            </button>
                                            <button type="button" onclick="openDeleteModal('@backup.FileName')" class="flex h-8 w-8 items-center justify-center rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors" title="Eliminar">
                                                <span class="material-symbols-outlined text-[16px]">delete</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Maintenance Zone -->
        <div class="bg-white dark:bg-[#1a2632] rounded-xl border-2 border-dashed border-red-200 dark:border-red-900 shadow-sm overflow-hidden">
            <button type="button" onclick="toggleMaintenance()" class="w-full p-4 flex items-center justify-between hover:bg-red-50/50 dark:hover:bg-red-900/10 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-red-500">warning</span>
                    <div class="text-left">
                        <h3 class="text-sm font-bold text-red-600 dark:text-red-400 uppercase tracking-wider">Zona de Mantenimiento</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Acciones avanzadas y destructivas</p>
                    </div>
                </div>
                <span id="maintenanceArrow" class="material-symbols-outlined text-red-400 transition-transform">expand_more</span>
            </button>
            <div id="maintenancePanel" class="hidden border-t border-red-100 dark:border-red-900/50">
                <div class="p-6">
                    <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-4 mb-4">
                        <p class="text-sm text-red-700 dark:text-red-300 font-medium">Resetear Base de Datos</p>
                        <p class="text-xs text-red-600 dark:text-red-400 mt-1">Esta acci&oacute;n eliminar&aacute; <strong>TODOS</strong> los datos del sistema (productos, ventas, clientes, etc.) y lo dejar&aacute; como reci&eacute;n instalado con el usuario administrador por defecto. Esta acci&oacute;n NO se puede deshacer.</p>
                    </div>
                    <div class="flex items-end gap-3">
                        <div class="flex-1">
                            <label class="text-xs font-medium text-red-600 dark:text-red-400 mb-1 block">Escribe RESETEAR para confirmar:</label>
                            <input type="text" id="resetConfirmInput" oninput="checkResetInput()" class="h-10 w-full rounded-lg border border-red-300 dark:border-red-800 bg-white dark:bg-gray-900 px-3 text-sm focus:border-red-500 focus:ring-1 focus:ring-red-500" placeholder="Escribe RESETEAR">
                        </div>
                        <button type="button" id="resetBtn" disabled onclick="openResetModal()" class="h-10 px-4 rounded-lg bg-red-600 text-white text-sm font-medium opacity-50 cursor-not-allowed transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">delete_forever</span>
                            Resetear BD
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Modal: Restore Confirmation -->
<div id="restoreModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#1a2632] rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="p-6 border-b border-[#dbe0e6] dark:border-gray-800 bg-blue-50 dark:bg-blue-900/20">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400">
                    <span class="material-symbols-outlined">restore</span>
                </div>
                <h3 class="text-lg font-bold text-[#111418] dark:text-white">Restaurar Respaldo</h3>
            </div>
        </div>
        <div class="p-6">
            <p class="text-sm text-[#617589] dark:text-gray-400 mb-3">Est&aacute;s a punto de restaurar la base de datos desde:</p>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-3 mb-3">
                <p class="text-sm font-mono font-medium text-[#111418] dark:text-white" id="restoreFileName"></p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1" id="restoreFileDate"></p>
            </div>
            <div class="bg-orange-50 dark:bg-orange-900/20 rounded-lg p-3 border border-orange-200 dark:border-orange-800">
                <p class="text-xs text-orange-700 dark:text-orange-300" id="restoreWarningText"></p>
            </div>
        </div>
        <div class="p-4 border-t border-[#dbe0e6] dark:border-gray-800 flex justify-end gap-3">
            <button type="button" onclick="closeModal('restoreModal')" class="h-10 px-4 rounded-lg border border-[#dbe0e6] dark:border-gray-700 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Cancelar
            </button>
            <form id="restoreForm" asp-action="RestoreBackup" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="fileName" id="restoreFileNameInput" />
                <button type="submit" class="h-10 px-4 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">restore</span>
                    S&iacute;, Restaurar
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Delete Confirmation -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#1a2632] rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="p-6 border-b border-[#dbe0e6] dark:border-gray-800 bg-red-50 dark:bg-red-900/20">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400">
                    <span class="material-symbols-outlined">delete</span>
                </div>
                <h3 class="text-lg font-bold text-[#111418] dark:text-white">Eliminar Respaldo</h3>
            </div>
        </div>
        <div class="p-6">
            <p class="text-sm text-[#617589] dark:text-gray-400">Se eliminar&aacute; permanentemente el archivo:</p>
            <p class="text-sm font-mono font-medium text-[#111418] dark:text-white mt-2 bg-gray-50 dark:bg-gray-800 rounded-lg p-3" id="deleteFileName"></p>
        </div>
        <div class="p-4 border-t border-[#dbe0e6] dark:border-gray-800 flex justify-end gap-3">
            <button type="button" onclick="closeModal('deleteModal')" class="h-10 px-4 rounded-lg border border-[#dbe0e6] dark:border-gray-700 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Cancelar
            </button>
            <form id="deleteForm" asp-action="DeleteBackup" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="fileName" id="deleteFileNameInput" />
                <button type="submit" class="h-10 px-4 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">delete</span>
                    Eliminar
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Reset Confirmation -->
<div id="resetModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-[#1a2632] rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="p-6 border-b border-[#dbe0e6] dark:border-gray-800 bg-red-50 dark:bg-red-900/20">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400">
                    <span class="material-symbols-outlined">delete_forever</span>
                </div>
                <h3 class="text-lg font-bold text-red-600 dark:text-red-400">RESETEAR BASE DE DATOS</h3>
            </div>
        </div>
        <div class="p-6">
            <p class="text-sm text-red-700 dark:text-red-300 font-medium mb-2">Esta acci&oacute;n es IRREVERSIBLE.</p>
            <ul class="text-xs text-red-600 dark:text-red-400 space-y-1 list-disc list-inside">
                <li>Se eliminar&aacute;n TODOS los productos, ventas, clientes y gastos</li>
                <li>Se eliminar&aacute;n TODOS los usuarios excepto el administrador por defecto</li>
                <li>El sistema quedar&aacute; como reci&eacute;n instalado</li>
                <li>El sistema se reiniciar&aacute; autom&aacute;ticamente (espere ~15 segundos)</li>
                <li>Se recomienda crear un respaldo antes de continuar</li>
            </ul>
        </div>
        <div class="p-4 border-t border-[#dbe0e6] dark:border-gray-800 flex justify-end gap-3">
            <button type="button" onclick="closeModal('resetModal')" class="h-10 px-4 rounded-lg border border-[#dbe0e6] dark:border-gray-700 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Cancelar
            </button>
            <form asp-action="ResetDatabase" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="confirmText" value="RESETEAR" />
                <button type="submit" class="h-10 px-4 rounded-lg bg-red-700 text-white text-sm font-bold hover:bg-red-800 transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">delete_forever</span>
                    RESETEAR TODO
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRestoreModal(fileName, fileDate, type) {
            document.getElementById('restoreFileName').textContent = fileName;
            document.getElementById('restoreFileDate').textContent = 'Creado: ' + fileDate;
            document.getElementById('restoreFileNameInput').value = fileName;

            const warningText = document.getElementById('restoreWarningText');
            if (type === 'database') {
                warningText.innerHTML = '<strong>Advertencia:</strong> Esto reemplazar&aacute; todos los datos actuales con los del respaldo. La sesi&oacute;n actual se cerrar&aacute;.';
            } else {
                warningText.innerHTML = '<strong>Advertencia:</strong> Esto reemplazar&aacute; todas las im&aacute;genes de productos actuales con las del respaldo. Esta acci&oacute;n no se puede deshacer.';
            }

            const modal = document.getElementById('restoreModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function openDeleteModal(fileName) {
            document.getElementById('deleteFileName').textContent = fileName;
            document.getElementById('deleteFileNameInput').value = fileName;
            const modal = document.getElementById('deleteModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function openResetModal() {
            const modal = document.getElementById('resetModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function toggleMaintenance() {
            const panel = document.getElementById('maintenancePanel');
            const arrow = document.getElementById('maintenanceArrow');
            panel.classList.toggle('hidden');
            arrow.classList.toggle('rotate-180');
        }

        function checkResetInput() {
            const input = document.getElementById('resetConfirmInput');
            const btn = document.getElementById('resetBtn');
            if (input.value === 'RESETEAR') {
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                btn.classList.add('hover:bg-red-700');
            } else {
                btn.disabled = true;
                btn.classList.add('opacity-50', 'cursor-not-allowed');
                btn.classList.remove('hover:bg-red-700');
            }
        }

        // Close modals on background click
        ['restoreModal', 'deleteModal', 'resetModal'].forEach(id => {
            document.getElementById(id).addEventListener('click', function(e) {
                if (e.target === this) closeModal(id);
            });
        });

        // Close modals on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                ['restoreModal', 'deleteModal', 'resetModal'].forEach(id => closeModal(id));
            }
        });
    </script>
}
