@model SistemaInventario.Models.ViewModels.ImageDiagnosticViewModel

@{
    ViewData["Title"] = "Diagnóstico de Imágenes";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Diagnóstico de Imágenes</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Verifica qué productos tienen imágenes faltantes en disco</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Backups" class="flex items-center gap-2 rounded-lg bg-gray-100 dark:bg-gray-700 px-4 py-2 text-sm font-medium text-[#111418] dark:text-white hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Respaldos
            </a>
            <a asp-action="ImageDiagnostic" class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors">
                <span class="material-symbols-outlined text-[20px]">refresh</span>
                Reanalizar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto flex max-w-[1000px] flex-col gap-6">

        <!-- Tarjetas resumen -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#dbe0e6] dark:border-gray-800 p-5 flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-900/30">
                    <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-2xl">image</span>
                </div>
                <div>
                    <p class="text-2xl font-bold text-[#111418] dark:text-white">@Model.TotalConImagen</p>
                    <p class="text-sm text-[#617589] dark:text-gray-400">Con imagen registrada</p>
                </div>
            </div>

            <div class="bg-white dark:bg-[#1a2632] rounded-xl border @(Model.TotalFaltantes > 0 ? "border-red-200 dark:border-red-900/50" : "border-[#dbe0e6] dark:border-gray-800") p-5 flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl @(Model.TotalFaltantes > 0 ? "bg-red-100 dark:bg-red-900/30" : "bg-green-100 dark:bg-green-900/30")">
                    <span class="material-symbols-outlined @(Model.TotalFaltantes > 0 ? "text-red-600 dark:text-red-400" : "text-green-600 dark:text-green-400") text-2xl">
                        @(Model.TotalFaltantes > 0 ? "broken_image" : "check_circle")
                    </span>
                </div>
                <div>
                    <p class="text-2xl font-bold @(Model.TotalFaltantes > 0 ? "text-red-600 dark:text-red-400" : "text-green-600 dark:text-green-400")">@Model.TotalFaltantes</p>
                    <p class="text-sm text-[#617589] dark:text-gray-400">Archivos faltantes</p>
                </div>
            </div>

            <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#dbe0e6] dark:border-gray-800 p-5 flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800">
                    <span class="material-symbols-outlined text-slate-500 text-2xl">hide_image</span>
                </div>
                <div>
                    <p class="text-2xl font-bold text-[#111418] dark:text-white">@Model.TotalSinImagen</p>
                    <p class="text-sm text-[#617589] dark:text-gray-400">Sin imagen asignada</p>
                </div>
            </div>
        </div>

        @if (Model.TotalFaltantes == 0)
        {
            <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-900/40 rounded-xl p-6 flex items-center gap-4">
                <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-3xl">check_circle</span>
                <div>
                    <p class="font-semibold text-green-800 dark:text-green-300">Todo en orden</p>
                    <p class="text-sm text-green-700 dark:text-green-400">Todos los archivos de imagen están presentes en disco.</p>
                </div>
            </div>
        }
        else
        {
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/40 rounded-xl p-4 flex items-center gap-3">
                <span class="material-symbols-outlined text-red-500 text-2xl">warning</span>
                <p class="text-sm text-red-700 dark:text-red-400 font-medium">
                    Se encontraron <strong>@Model.TotalFaltantes</strong> productos con imagen registrada en la base de datos pero sin archivo en disco.
                    Para recuperarlos, usa <a asp-action="Backups" class="underline">Respaldos → Restaurar Imágenes</a>.
                </p>
            </div>

            <div class="bg-white dark:bg-[#1a2632] rounded-xl border border-[#dbe0e6] dark:border-gray-800 overflow-hidden">
                <div class="px-6 py-4 border-b border-[#dbe0e6] dark:border-gray-800">
                    <h3 class="font-semibold text-[#111418] dark:text-white">Productos afectados</h3>
                </div>
                <div class="divide-y divide-[#dbe0e6] dark:divide-gray-800">
                    @foreach (var item in Model.ImagenesFaltantes)
                    {
                        <div class="flex items-center gap-4 px-6 py-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                            <div class="h-10 w-10 shrink-0 rounded-lg bg-gray-100 dark:bg-gray-800 overflow-hidden">
                                <img src="/images/product-placeholder.svg" class="h-full w-full object-cover" alt="" />
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-[#111418] dark:text-white truncate">@item.Name</p>
                                <p class="text-xs text-gray-400 truncate font-mono">@item.ImageUrl</p>
                            </div>
                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id"
                               class="shrink-0 flex items-center gap-1 text-xs text-primary hover:text-blue-700 font-medium" onclick="event.stopPropagation()">
                                <span class="material-symbols-outlined text-[16px]">edit</span>
                                Subir imagen
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
