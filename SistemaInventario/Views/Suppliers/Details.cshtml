@model SistemaInventario.Models.Entities.Supplier
@{
    ViewData["Title"] = "Detalle de Proveedor";
}

<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[800px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold leading-tight">Detalle de Proveedor</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Información de contacto y perfil comercial</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Volver
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                <span class="material-symbols-outlined text-[20px]">edit</span>
                Editar
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[700px] flex flex-col gap-6">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-[#f0f2f4] dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">business</span>
                <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Información del Proveedor</h3>
            </div>
            <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex flex-col gap-1 md:col-span-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Razón Social</label>
                    <p class="text-xl font-bold text-[#111418] dark:text-white">@Model.Name</p>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Persona de Contacto</label>
                    <p class="text-base font-medium text-[#111418] dark:text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-gray-400">person</span>
                        @Model.ContactName
                    </p>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Teléfono</label>
                    <p class="text-base font-medium text-[#111418] dark:text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-gray-400">call</span>
                        @Model.Phone
                    </p>
                </div>

                <div class="flex flex-col gap-1 md:col-span-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-[#617589] dark:text-gray-500">Correo Electrónico</label>
                    <p class="text-base font-medium text-[#111418] dark:text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-gray-400">mail</span>
                        @Model.Email
                    </p>
                </div>
            </div>
        </div>

        <!-- Action Card -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-blue-50 dark:bg-blue-900/10 rounded-2xl p-5 border border-blue-100 dark:border-blue-900/30 flex items-center gap-4">
                <div class="bg-white dark:bg-gray-800 p-2 rounded-lg shadow-sm">
                    <span class="material-symbols-outlined text-primary">shopping_bag</span>
                </div>
                <div>
                    <p class="text-xs font-bold text-blue-800 dark:text-blue-300 uppercase">Productos</p>
                    <p class="text-sm text-blue-700 dark:text-blue-400">Ver catálogo asignado</p>
                </div>
            </div>
            <div class="bg-green-50 dark:bg-green-900/10 rounded-2xl p-5 border border-green-100 dark:border-green-900/30 flex items-center gap-4">
                <div class="bg-white dark:bg-gray-800 p-2 rounded-lg shadow-sm">
                    <span class="material-symbols-outlined text-green-600">history</span>
                </div>
                <div>
                    <p class="text-xs font-bold text-green-800 dark:text-green-300 uppercase">Compras</p>
                    <p class="text-sm text-green-700 dark:text-green-400">Historial de facturas</p>
                </div>
            </div>
        </div>
    </div>
</div>
