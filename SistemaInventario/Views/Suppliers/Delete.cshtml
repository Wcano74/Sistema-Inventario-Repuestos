@model SistemaInventario.Models.Entities.Supplier
@{
    ViewData["Title"] = "Eliminar Proveedor";
}

<div class="p-6">
    <div class="mx-auto max-w-[500px] flex flex-col gap-6 pt-12">
        <div class="bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-xl overflow-hidden">
            <div class="p-8 flex flex-col items-center text-center gap-4">
                <div class="size-20 bg-red-50 dark:bg-red-900/20 rounded-full flex items-center justify-center mb-2">
                    <span class="material-symbols-outlined text-red-500 text-[40px]">person_remove</span>
                </div>
                <h3 class="text-xl font-bold text-[#111418] dark:text-white">¿Eliminar Proveedor?</h3>
                <p class="text-sm text-[#617589] dark:text-gray-400">
                    Estás a punto de eliminar al proveedor <span class="font-bold text-[#111418] dark:text-white">"@Model.Name"</span>. 
                    Asegúrate de que no existan productos vinculados a este proveedor.
                </p>

                <div class="w-full bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 mt-2 text-left">
                    <div class="flex justify-between items-center mb-2">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Contacto</p>
                        <p class="text-xs text-gray-900 dark:text-white font-medium">@Model.ContactName</p>
                    </div>
                    <div class="flex justify-between items-center">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Teléfono</p>
                        <p class="text-xs text-gray-900 dark:text-white font-medium">@Model.Phone</p>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center gap-0 border-t border-[#f0f2f4] dark:border-gray-800">
                <a asp-action="Index" class="flex-1 h-16 flex items-center justify-center text-sm font-bold text-[#617589] hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors border-r border-[#f0f2f4] dark:border-gray-800">
                    Cancelar
                </a>
                <form asp-action="Delete" method="post" class="flex-1">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="w-full h-16 flex items-center justify-center text-sm font-bold text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                        Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
