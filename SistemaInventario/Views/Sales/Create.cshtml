@using System.Text.Json
@inject SistemaInventario.Services.IConfigurationService Config
@{
    ViewData["Title"] = "Punto de Venta";
    // Serialize products to JSON for JS usage
    var productsJson = JsonSerializer.Serialize(ViewBag.Products);
    var symbol = await Config.GetCurrencySymbolAsync();
}

<style>
    /* Force layout overflow hidden for POS */
    .main-content {
        overflow: hidden !important;
    }
    
    /* Custom scrollbar for customer results */
    #customerResultsList::-webkit-scrollbar {
        width: 4px;
    }
    #customerResultsList::-webkit-scrollbar-thumb {
        background: #d1d5db;
        border-radius: 10px;
    }
</style>

<!-- POS Header -->
<header class="w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-20 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-3">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1400px] mx-auto">
        <div class="flex flex-col">
            <h2 class="text-[#111418] dark:text-white text-xl font-bold leading-tight">Punto de Venta</h2>
            <p class="text-[#617589] dark:text-gray-400 text-[10px] uppercase tracking-wider font-bold">Terminal de facturación rápida</p>
        </div>
        <div class="flex items-center gap-3">
            <div id="statusIndicator" class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-100 text-green-700 text-xs font-medium dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
            </div>
            <a asp-action="Index" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">history</span>
                Historial
            </a>
        </div>
    </div>
</header>

<div class="flex flex-col lg:flex-row h-[calc(100vh-65px)] overflow-hidden bg-[#f8f9fa] dark:bg-[#101922]">
    <!-- Left Column: Search & Cart -->
    <div class="flex-1 flex flex-col p-6 overflow-hidden">
        <!-- Search Area -->
        <div class="relative flex flex-col gap-2 mb-6">
            <div class="relative flex items-center shadow-sm">
                <span class="material-symbols-outlined absolute left-4 text-[#617589] dark:text-gray-400">search</span>
                <input type="text" id="productSearch" 
                       class="h-14 w-full rounded-xl border border-[#dbe0e6] bg-white pl-12 pr-4 text-base text-[#111418] focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-gray-700 dark:bg-[#1a2632] dark:text-white transition-all shadow-inner" 
                       placeholder="Escanear código de barras o buscar por nombre..." autofocus autocomplete="off">
            </div>
            
            <!-- Floating Search Results -->
            <div id="searchResults" class="absolute top-16 left-0 w-full bg-white dark:bg-[#1a2632] rounded-xl border border-[#dbe0e6] dark:border-gray-700 shadow-2xl z-50 max-h-[400px] overflow-y-auto hidden">
                <!-- Dynamic results -->
            </div>
        </div>

        <!-- Cart Area -->
        <div class="flex-1 bg-white dark:bg-[#1a2632] rounded-2xl border border-[#dbe0e6] dark:border-gray-700 shadow-sm flex flex-col overflow-hidden">
            <div class="p-4 border-b border-[#f0f2f4] dark:border-gray-700 flex justify-between items-center bg-gray-50/50 dark:bg-gray-800/30">
                <h3 class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Carrito de Compra</h3>
                <span id="itemCountBadge" class="px-2.5 py-0.5 rounded-full bg-primary/10 text-primary text-xs font-bold">0 Items</span>
            </div>
            
            <div class="flex-1 overflow-y-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="sticky top-0 bg-white dark:bg-[#1a2632] shadow-sm z-10">
                        <tr class="text-[11px] font-bold text-[#617589] dark:text-gray-400 uppercase tracking-widest border-b border-[#f0f2f4] dark:border-gray-700">
                            <th class="px-6 py-4">Producto</th>
                            <th class="px-6 py-4 text-center">Cantidad</th>
                            <th class="px-6 py-4 text-center">% Desc.</th>
                            <th class="px-6 py-4 text-right">Unitario</th>
                            <th class="px-6 py-4 text-right">Subtotal</th>
                            <th class="px-6 py-4 text-center"></th>
                        </tr>
                    </thead>
                    <tbody id="cartTableBody" class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        <!-- Empty state -->
                        <tr id="emptyCartState">
                            <td colspan="5" class="py-20 text-center">
                                <div class="flex flex-col items-center gap-3 opacity-30">
                                    <span class="material-symbols-outlined text-[64px]">shopping_cart_off</span>
                                    <p class="text-lg font-medium">El carrito está vacío</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Quick Actions Footer -->
            <div class="p-4 bg-gray-50/50 dark:bg-gray-800/30 border-t border-[#f0f2f4] dark:border-gray-700 flex justify-between items-center">
                <button onclick="clearCart()" class="flex items-center gap-2 text-xs font-semibold text-red-500 hover:text-red-700 transition-colors uppercase tracking-tight">
                    <span class="material-symbols-outlined text-[18px]">delete_sweep</span>
                    Vaciar Carrito
                </button>
                <div class="flex gap-2 text-xs text-[#617589] dark:text-gray-500">
                   F1: Cobrar • Esc: Limpiar búsqueda
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Summary & Payment -->
    <div class="w-full lg:w-[400px] bg-white dark:bg-[#1a2632] border-l border-[#dbe0e6] dark:border-gray-700 flex flex-col shadow-xl z-20 overflow-hidden">
        <!-- Header (Fixed) -->
        <div class="p-6 pb-4 border-b border-[#dbe0e6] dark:border-gray-700">
            <h3 class="text-xl font-bold text-[#111418] dark:text-white">Resumen de Venta</h3>
        </div>
        
        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-6 pt-4">
            <div class="flex flex-col gap-4">
                <!-- Totals Card -->
                <div class="p-6 rounded-2xl bg-[#f8f9fa] dark:bg-gray-800/50 border border-[#dbe0e6] dark:border-gray-700 flex flex-col gap-4">
                    <div class="flex justify-between items-center text-[#617589] dark:text-gray-400">
                        <span class="text-sm">Subtotal</span>
                        <span id="summarySubtotal" class="font-medium">@(symbol)@("0.00")</span>
                    </div>
                    <div class="flex justify-between items-center text-[#617589] dark:text-gray-400">
                        <span class="text-sm">Impuestos (IVA 0%)</span>
                        <span class="font-medium">@(symbol)@("0.00")</span>
                    </div>
                    <div class="flex justify-between items-center text-orange-600 dark:text-orange-400 font-bold">
                        <span class="text-sm">Descuento Total</span>
                        <span id="summaryDiscount">@(symbol)@("0.00")</span>
                    </div>
                    <div class="h-px bg-dashed border-t border-dashed border-[#dbe0e6] dark:border-gray-700 my-2"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-base font-bold text-[#111418] dark:text-white">Total a Pagar</span>
                        <span id="grandTotal" class="text-3xl font-black text-primary">@(symbol)@("0.00")</span>
                    </div>
                </div>

                <!-- Global Discount Control -->
                <div class="p-4 rounded-xl border border-primary/20 bg-primary/5">
                    <label class="text-[10px] font-black text-primary uppercase tracking-[0.1em] mb-2 block">
                        Descuento Global (%) (Máx: @ViewBag.MaxDiscountPercent%)
                    </label>
                    <div class="flex items-center gap-3">
                        <input type="range" id="globalDiscountSlider" min="0" max="@ViewBag.MaxDiscountPercent" value="0" step="1" 
                               oninput="document.getElementById('globalDiscountInput').value = this.value; applyGlobalDiscount(this.value)"
                               class="flex-1 accent-primary">
                        <input type="number" id="globalDiscountInput" min="0" max="@ViewBag.MaxDiscountPercent" value="0" 
                               oninput="document.getElementById('globalDiscountSlider').value = this.value; applyGlobalDiscount(this.value)"
                               class="w-16 h-8 text-center text-xs font-bold rounded-lg border border-primary/30 bg-white dark:bg-gray-800 focus:outline-none focus:ring-1 focus:ring-primary">
                    </div>
                </div>

                <!-- Customer Search -->
                <div class="flex flex-col gap-2">
                    <label class="text-[10px] font-black text-[#617589] dark:text-gray-400 uppercase tracking-[0.1em]">
                        Cliente @(ViewBag.CustomerRequired ? "(Requerido)" : "(Opcional)")
                    </label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#617589] dark:text-gray-400 text-[20px] transition-colors group-focus-within:text-primary">person_search</span>
                        <input type="text" id="customerSearch" autocomplete="off"
                               class="h-11 w-full rounded-xl border border-[#dbe0e6] bg-white dark:bg-gray-800 pl-10 pr-4 text-sm text-[#111418] dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm"
                               placeholder="Buscar por Nombre o NIT (Atajo: F2)...">
                        <input type="hidden" id="customerSelect" value="@ViewBag.DefaultCustomerId">
                        
                        <!-- Customer Search Results -->
                        <div id="customerResults" class="hidden absolute top-full left-0 w-full mt-2 bg-white dark:bg-[#1a2632] rounded-xl border border-[#dbe0e6] dark:border-gray-700 shadow-2xl z-50 max-h-[300px] overflow-hidden flex flex-col">
                            <div id="customerResultsList" class="overflow-y-auto flex-1">
                                <!-- Dynamic results -->
                            </div>
                            @if (ViewBag.AllowQuickCreate)
                            {
                                <button type="button" onclick="quickCreateCustomer()" class="w-full p-4 bg-gray-50 dark:bg-gray-800/50 border-t border-[#dbe0e6] dark:border-gray-700 flex items-center justify-center gap-2 text-primary font-bold text-sm hover:bg-primary hover:text-white transition-all group">
                                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform">person_add</span>
                                    CREAR NUEVO CLIENTE
                                </button>
                            }
                        </div>
                    </div>
                    
                    <div id="selectedCustomerDisplay" class="flex items-center justify-between p-3 rounded-xl bg-primary/5 border border-primary/20 shadow-inner">
                        <div class="flex items-center gap-3">
                            <div class="size-8 rounded-full bg-primary/20 flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary text-[18px]">verified</span>
                            </div>
                            <div class="flex flex-col">
                                <span id="selectedCustomerName" class="text-sm font-bold text-primary">Cliente General</span>
                                <span id="selectedCustomerNit" class="text-[10px] text-primary/70 font-bold uppercase">Consumidor Final</span>
                            </div>
                        </div>
                        <button type="button" onclick="clearCustomerSelection()" id="btnClearCustomer" class="hidden text-red-500 hover:text-red-700 p-1 rounded-md hover:bg-red-50 transition-colors">
                            <span class="material-symbols-outlined text-[18px]">close</span>
                        </button>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="flex flex-col gap-3">
                    <label class="text-xs font-bold text-[#617589] dark:text-gray-400 uppercase tracking-widest">Método de Pago</label>
                    <div class="grid grid-cols-2 gap-2">
                        <button type="button" id="btnCash" onclick="selectPaymentMethod('Cash')" class="flex flex-col items-center justify-center gap-2 p-3 rounded-xl border-2 border-primary bg-primary/5 text-primary transition-all">
                            <span class="material-symbols-outlined font-variation-settings-fill-1">payments</span>
                            <span class="text-xs font-bold">Efectivo</span>
                        </button>
                        <button type="button" id="btnCard" onclick="selectPaymentMethod('Card')" class="flex flex-col items-center justify-center gap-2 p-3 rounded-xl border-2 border-[#dbe0e6] dark:border-gray-700 text-[#617589] hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
                            <span class="material-symbols-outlined">credit_card</span>
                            <span class="text-xs font-bold">Tarjeta</span>
                        </button>
                        <button type="button" id="btnTransfer" onclick="selectPaymentMethod('Transfer')" class="flex flex-col items-center justify-center gap-2 p-3 rounded-xl border-2 border-[#dbe0e6] dark:border-gray-700 text-[#617589] hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
                            <span class="material-symbols-outlined">account_balance</span>
                            <span class="text-xs font-bold">Transferencia</span>
                        </button>
                        <button type="button" id="btnMixed" onclick="selectPaymentMethod('Mixed')" class="flex flex-col items-center justify-center gap-2 p-3 rounded-xl border-2 border-[#dbe0e6] dark:border-gray-700 text-[#617589] hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
                            <span class="material-symbols-outlined">payments</span>
                            <span class="text-xs font-bold">Mixto</span>
                        </button>
                    </div>
                </div>
                
                <!-- Cash Amount Input (shown when cash is selected) -->
                <div id="cashAmountSection" class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-[#617589] dark:text-gray-400 uppercase tracking-widest">Monto Recibido</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-bold">@symbol</span>
                        <input type="number" id="amountPaid" step="0.01" min="0" 
                               class="h-12 w-full rounded-xl border border-[#dbe0e6] dark:border-gray-700 bg-white dark:bg-gray-800 pl-10 pr-4 text-lg font-bold focus:ring-2 focus:ring-primary/20 focus:border-primary"
                               placeholder="0.00" oninput="calculateChange()">
                    </div>
                    <div id="changeDisplay" class="hidden p-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-bold text-green-900 dark:text-green-400">Cambio:</span>
                            <span id="changeAmount" class="text-xl font-black text-green-600 dark:text-green-400">@symbol 0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons (Fixed at bottom) -->
        <div class="p-6 pt-4 border-t border-[#dbe0e6] dark:border-gray-700 bg-white dark:bg-[#1a2632]">
            @if (!ViewBag.HasOpenCashRegister && ViewBag.CashRegisterRequired)
            {
                <div class="p-4 rounded-xl bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 mb-3">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-yellow-600 dark:text-yellow-400 text-[20px]">warning</span>
                        <div>
                            <p class="text-xs font-bold text-yellow-900 dark:text-yellow-400">Caja Cerrada</p>
                            <p class="text-xs text-yellow-700 dark:text-yellow-500 mt-1">Debe abrir una caja para realizar ventas en efectivo.</p>
                            <a href="/caja/abrir" class="inline-block mt-2 text-xs font-bold text-yellow-900 dark:text-yellow-400 hover:underline">Abrir Caja →</a>
                        </div>
                    </div>
                </div>
            }
            <button onclick="processSale()" class="group relative flex h-16 w-full items-center justify-center overflow-hidden rounded-2xl bg-primary px-8 text-white transition-all hover:bg-blue-600 active:scale-95 shadow-lg shadow-blue-500/30">
                <div class="flex items-center gap-3 font-black text-lg">
                    <span class="material-symbols-outlined text-[28px]">fact_check</span>
                    PROCESAR COBRO
                </div>
            </button>
        </div>
    </div>
</div>

<!-- Quick Create Customer Modal -->
<div id="quickCreateModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-[#1a2632] rounded-2xl shadow-2xl max-w-md w-full p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-[#111418] dark:text-white">Crear Cliente Rápido</h3>
            <button onclick="closeQuickCreateModal()" class="text-gray-500 hover:text-gray-700">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 mb-1">Nombre *</label>
                <input type="text" id="quickName" class="w-full h-10 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 text-sm focus:ring-2 focus:ring-primary/20" required>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 mb-1">NIT/DPI</label>
                <input type="text" id="quickNit" class="w-full h-10 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 text-sm focus:ring-2 focus:ring-primary/20">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 mb-1">Teléfono</label>
                <input type="text" id="quickPhone" class="w-full h-10 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 text-sm focus:ring-2 focus:ring-primary/20">
            </div>
        </div>
        <div class="flex gap-2 mt-6">
            <button onclick="closeQuickCreateModal()" class="flex-1 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-bold py-2 px-4 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600">
                Cancelar
            </button>
            <button onclick="saveQuickCustomer()" class="flex-1 bg-primary text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-600">
                Guardar
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Data from Server
        const allProducts = @Html.Raw(productsJson);
        
        // POS Cart Persistence Configuration
        const CART_AUTO_SAVE = @(ViewBag.POSCartAutoSave ? "true" : "false");
        const CART_EXPIRATION_MINUTES = @ViewBag.POSCart_ExpirationMinutes;
        const CART_STORAGE_KEY = 'pos_cart_@User.Identity.Name';
        const MAX_DISCOUNT_PERCENT = @ViewBag.MaxDiscountPercent;
        
        // Payment and Customer State
        let selectedPaymentMethod = '@ViewBag.DefaultPaymentMethod'; // Cash, Card, Transfer, Mixed
        let selectedCustomerId = @ViewBag.DefaultCustomerId;
        let selectedCustomerName = 'Cliente General';
        const hasOpenCashRegister = @(ViewBag.HasOpenCashRegister ? "true" : "false");
        const cashRegisterRequired = @(ViewBag.CashRegisterRequired ? "true" : "false");
        const customerRequired = @(ViewBag.CustomerRequired ? "true" : "false");
        
        // All customers data
        const allCustomers = @Html.Raw(JsonSerializer.Serialize(ViewBag.Customers));
        
        // State
        let cart = []; // Array of { productId, name, price, cost, quantity, discountPercent, subtotal, maxStock, image }

        // ========== Customer Search Functions ==========
        const customerSearchInput = document.getElementById('customerSearch');
        const customerResultsDiv = document.getElementById('customerResults');
        const selectedCustomerDisplay = document.getElementById('selectedCustomerDisplay');
        const selectedCustomerNameSpan = document.getElementById('selectedCustomerName');

        // Initialize with default customer
        document.addEventListener('DOMContentLoaded', function() {
            const defaultCustomer = allCustomers.find(c => c.Id === @ViewBag.DefaultCustomerId);
            if (defaultCustomer) {
                selectCustomer(defaultCustomer.Id, defaultCustomer.Name, defaultCustomer.NitDpi);
            }
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                processSale();
            }
            if (e.key === 'F2') {
                e.preventDefault();
                customerSearchInput.focus();
            }
            if (e.key === 'Escape') {
                resultsDiv.classList.add('hidden');
                customerResultsDiv.classList.add('hidden');
                searchInput.value = '';
                customerSearchInput.value = '';
            }
        });

        // Customer search input handler
        customerSearchInput.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase().trim();
            
            if (term.length < 1) {
                customerResultsDiv.classList.add('hidden');
                return;
            }

            const matches = allCustomers.filter(c => 
                (c.Name && c.Name.toLowerCase().includes(term)) || 
                (c.NitDpi && c.NitDpi.toLowerCase().includes(term)) ||
                (c.Phone && c.Phone.toLowerCase().includes(term))
            );

            renderCustomerResults(matches);
        });

        // Close customer results when clicking outside
        document.addEventListener('click', function(e) {
            if (!customerSearchInput.contains(e.target) && !customerResultsDiv.contains(e.target)) {
                customerResultsDiv.classList.add('hidden');
            }
        });

        function renderCustomerResults(matches) {
            const resultsList = document.getElementById('customerResultsList');
            resultsList.innerHTML = '';
            
            if (matches.length === 0) {
                resultsList.innerHTML = '<div class="p-6 text-center text-sm text-gray-500 italic">No se encontraron clientes con esos datos</div>';
                customerResultsDiv.classList.remove('hidden');
                return;
            }

            matches.forEach(customer => {
                const item = document.createElement('div');
                item.className = 'flex items-center gap-4 p-4 hover:bg-primary/10 cursor-pointer border-b border-gray-100 dark:border-gray-800 last:border-0 transition-colors group';
                
                const term = customerSearchInput.value.toLowerCase();
                const highlightedNit = customer.NitDpi && term ? customer.NitDpi.replace(new RegExp(term, 'gi'), match => `<span class="bg-yellow-200 dark:bg-yellow-900 text-black dark:text-white px-1 rounded">${match}</span>`) : (customer.NitDpi || 'C/F');

                item.innerHTML = `
                    <div class="flex-shrink-0">
                        <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[20px]">person</span>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-bold text-gray-900 dark:text-white truncate">${customer.Name}</div>
                        <div class="text-[11px] font-black text-primary/60 dark:text-primary/40 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">id_card</span>
                            ${highlightedNit}
                        </div>
                    </div>
                    ${customer.Id === selectedCustomerId ? '<span class="material-symbols-outlined text-green-500 text-[22px]">check_circle</span>' : ''}
                `;
                
                item.onclick = (e) => {
                    e.stopPropagation();
                    selectCustomer(customer.Id, customer.Name, customer.NitDpi);
                    customerSearchInput.value = '';
                    customerResultsDiv.classList.add('hidden');
                };
                
                resultsList.appendChild(item);
            });
            
            customerResultsDiv.classList.remove('hidden');
        }

        function selectCustomer(customerId, customerName, nit) {
            selectedCustomerId = customerId;
            selectedCustomerName = customerName;
            document.getElementById('customerSelect').value = customerId;
            selectedCustomerNameSpan.textContent = customerName;
            document.getElementById('selectedCustomerNit').textContent = nit || 'Consumidor Final';
            
            // Show/hide clear button
            const clearBtn = document.getElementById('btnClearCustomer');
            if (customerId !== @ViewBag.DefaultCustomerId) {
                clearBtn.classList.remove('hidden');
            } else {
                clearBtn.classList.add('hidden');
            }
        }

        function clearCustomerSelection() {
            const defaultCustomer = allCustomers.find(c => c.Id === @ViewBag.DefaultCustomerId);
            if (defaultCustomer) {
                selectCustomer(defaultCustomer.Id, defaultCustomer.Name, defaultCustomer.NitDpi);
            }
        }

        // ========== LocalStorage Functions ==========
        function saveCartToLocalStorage() {
            if (!CART_AUTO_SAVE) return;
            
            const cartData = {
                items: cart,
                timestamp: new Date().getTime(),
                expiresAt: new Date().getTime() + (CART_EXPIRATION_MINUTES * 60 * 1000)
            };
            
            try {
                localStorage.setItem(CART_STORAGE_KEY, JSON.stringify(cartData));
                showAutoSaveIndicator();
            } catch (e) {
                console.error('Error guardando carrito:', e);
            }
        }

        function loadCartFromLocalStorage() {
            if (!CART_AUTO_SAVE) return null;
            
            try {
                const stored = localStorage.getItem(CART_STORAGE_KEY);
                if (!stored) return null;
                
                const cartData = JSON.parse(stored);
                const now = new Date().getTime();
                
                // Verificar expiración
                if (now > cartData.expiresAt) {
                    localStorage.removeItem(CART_STORAGE_KEY);
                    return null;
                }
                
                return cartData.items;
            } catch (e) {
                console.error('Error cargando carrito:', e);
                return null;
            }
        }

        function clearSavedCart() {
            try {
                localStorage.removeItem(CART_STORAGE_KEY);
            } catch (e) {
                console.error('Error limpiando carrito:', e);
            }
        }

        function showAutoSaveIndicator() {
            // Mostrar indicador temporal de guardado
            const indicator = document.getElementById('statusIndicator');
            const originalContent = indicator.innerHTML;
            indicator.innerHTML = '<span class="material-symbols-outlined text-[14px]">cloud_done</span> Guardado';
            setTimeout(() => {
                indicator.innerHTML = originalContent;
            }, 1500);
        }

        // Elements
        const searchInput = document.getElementById('productSearch');
        const resultsDiv = document.getElementById('searchResults');
        const cartBody = document.getElementById('cartTableBody');
        const totalSpan = document.getElementById('grandTotal');
        const subtotalSpan = document.getElementById('summarySubtotal');
        const emptyCartState = document.getElementById('emptyCartState');
        const itemCountBadge = document.getElementById('itemCountBadge');

        // Close search when clicking outside
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
                resultsDiv.classList.add('hidden');
            }
        });

        // Search Logic
        searchInput.addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            if (term.length < 2) {
                resultsDiv.classList.add('hidden');
                return;
            }

            const matches = allProducts.filter(p =>
                (p.Name && p.Name.toLowerCase().includes(term)) ||
                (p.Barcode && p.Barcode.toLowerCase().includes(term))
            );

            renderResults(matches);
        });

        function renderResults(matches) {
            resultsDiv.innerHTML = '';
            if (matches.length === 0) {
                resultsDiv.innerHTML = '<div class="p-4 text-center text-[#617589]">No se encontraron productos</div>';
                resultsDiv.classList.remove('hidden');
                return;
            }

            matches.forEach(p => {
                const item = document.createElement('div');
                item.className = 'flex items-center gap-4 p-4 hover:bg-primary/10 cursor-pointer border-b border-[#f0f2f4] dark:border-gray-800 transition-colors group';
                
                const imgHtml = p.ImageUrl 
                    ? `<img class="h-10 w-10 rounded-lg object-cover" src="${p.ImageUrl}">`
                    : `<div class="h-10 w-10 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400"><span class="material-symbols-outlined text-[20px]">image</span></div>`;

                item.innerHTML = `
                    <div class="shrink-0">${imgHtml}</div>
                    <div class="flex-1">
                        <div class="text-sm font-bold text-[#111418] dark:text-white group-hover:text-primary transition-colors">${p.Name}</div>
                        <div class="text-xs text-[#617589] dark:text-gray-400">
                            SKU: ${p.Barcode || 'N/A'} • 
                            Stock: <span class="${p.StockQuantity <= 5 ? 'text-red-500 font-bold' : ''}">${p.StockQuantity}</span>
                            ${p.LocationCode ? ` • <span class="inline-flex items-center gap-0.5 rounded bg-blue-50 dark:bg-blue-900/20 px-1 py-0.5 text-[10px] font-bold text-primary dark:text-blue-400 border border-blue-100 dark:border-blue-900/30"><span class="material-symbols-outlined text-[12px]">pin_drop</span>${p.LocationCode}</span>` : ''}
                        </div>
                    </div>
                    <div class="text-sm font-black text-primary">@symbol${p.Price.toFixed(2)}</div>
                `;
                
                item.onclick = (e) => {
                    addToCart(p);
                    searchInput.value = '';
                    resultsDiv.classList.add('hidden');
                    searchInput.focus();
                };
                resultsDiv.appendChild(item);
            });
            resultsDiv.classList.remove('hidden');
        }

        // Initialize Cart from LocalStorage
        document.addEventListener('DOMContentLoaded', function() {
            const savedItems = loadCartFromLocalStorage();
            if (savedItems && savedItems.length > 0) {
                cart = savedItems;
                renderCart();
                
                // Indicate restoration
                const indicator = document.getElementById('statusIndicator');
                const originalHtml = indicator.innerHTML;
                indicator.innerHTML = '<span class="material-symbols-outlined text-[14px]">restore</span> Restaurado';
                setTimeout(() => {
                    indicator.innerHTML = originalHtml;
                }, 2000);
            }
        });

        function addToCart(product) {
            if (product.StockQuantity <= 0) {
                showToast('Sin stock disponible para este producto.', 'error');
                return;
            }

            const existing = cart.find(i => i.productId === product.Id);
            if (existing) {
                if(existing.quantity + 1 > product.StockQuantity) {
                    showToast('No hay suficiente stock.', 'error');
                    return;
                }
                existing.quantity++;
                existing.subtotal = existing.quantity * existing.price;
            } else {
                cart.push({
                    productId: product.Id,
                    name: product.Name,
                    price: product.Price,
                    cost: product.Cost,
                    quantity: 1,
                    discountPercent: 0,
                    subtotal: product.Price,
                    maxStock: product.StockQuantity,
                    image: product.ImageUrl
                });
            }
            renderCart();
            saveCartToLocalStorage();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
            saveCartToLocalStorage();
        }

        function updateQuantity(index, newQty) {
            const item = cart[index];
            newQty = parseInt(newQty);
            if(isNaN(newQty) || newQty <= 0) {
                removeFromCart(index);
                return;
            }
            if(newQty > item.maxStock) {
                showToast('Cantidad excede el stock disponible', 'error');
                item.quantity = item.maxStock;
            } else {
                item.quantity = newQty;
            }
            calculateItemSubtotal(item);
            renderCart();
            saveCartToLocalStorage();
        }

        function updateDiscount(index, newPercent) {
            const item = cart[index];
            newPercent = parseFloat(newPercent) || 0;
            
            if (newPercent < 0) newPercent = 0;
            if (newPercent > MAX_DISCOUNT_PERCENT) {
                showToast('El descuento excede el máximo permitido (' + MAX_DISCOUNT_PERCENT + '%)', 'warning');
                newPercent = MAX_DISCOUNT_PERCENT;
            }

            item.discountPercent = newPercent;
            calculateItemSubtotal(item);
            renderCart();
            saveCartToLocalStorage();
        }

        function applyGlobalDiscount(percent) {
            percent = parseFloat(percent) || 0;
            if (percent > MAX_DISCOUNT_PERCENT) percent = MAX_DISCOUNT_PERCENT;
            
            cart.forEach(item => {
                item.discountPercent = percent;
                calculateItemSubtotal(item);
            });
            renderCart();
            saveCartToLocalStorage();
        }

        function calculateItemSubtotal(item) {
            // Profit margin logic
            const margin = item.price - item.cost;
            let discountPerUnit = 0;
            if (margin > 0) {
                discountPerUnit = margin * (item.discountPercent / 100);
            }
            const finalPrice = item.price - discountPerUnit;
            item.subtotal = finalPrice * item.quantity;
        }

        function renderCart() {
            // Remove existing product rows
            const rows = cartBody.querySelectorAll('tr:not(#emptyCartState)');
            rows.forEach(r => r.remove());

            let subtotalTotal = 0;
            let totalDiscount = 0;
            let totalItems = 0;

            if (cart.length === 0) {
                emptyCartState.style.display = 'table-row';
            } else {
                emptyCartState.style.display = 'none';
                cart.forEach((item, index) => {
                    const originalSubtotal = item.price * item.quantity;
                    subtotalTotal += originalSubtotal;
                    
                    // Margin check for visual indicator
                    const margin = item.price - item.cost;
                    const isZeroMargin = margin <= 0;

                    totalItems += item.quantity;
                    
                    const imgHtml = item.image 
                        ? `<img class="h-10 w-10 rounded-lg object-cover" src="${item.image}">`
                        : `<div class="h-10 w-10 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400 dark:bg-gray-800"><span class="material-symbols-outlined text-[20px]">package_2</span></div>`;

                    const row = document.createElement('tr');
                    row.className = 'hover:bg-gray-50 dark:hover:bg-gray-800/20 transition-colors group';
                    row.innerHTML = `
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                ${imgHtml}
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-[#111418] dark:text-white">${item.name}</span>
                                    <span class="text-[10px] text-[#617589] dark:text-gray-400">Stock Max: ${item.maxStock}${isZeroMargin ? ' • <span class="text-xs text-orange-500 font-bold">Sin margen de desc.</span>' : ''}</span>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-center gap-2">
                                <button onclick="updateQuantity(${index}, ${item.quantity - 1})" class="size-8 rounded-lg border border-[#dbe0e6] dark:border-gray-700 hover:bg-primary/10 hover:text-primary transition-colors flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[16px]">remove</span>
                                </button>
                                <input type="number" class="w-12 h-8 text-center text-sm font-bold bg-transparent border-none focus:ring-0 appearance-none" 
                                    value="${item.quantity}" onchange="updateQuantity(${index}, this.value)">
                                <button onclick="updateQuantity(${index}, ${item.quantity + 1})" class="size-8 rounded-lg border border-[#dbe0e6] dark:border-gray-700 hover:bg-primary/10 hover:text-primary transition-colors flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[16px]">add</span>
                                </button>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                             <div class="flex items-center justify-center">
                                <input type="number" min="0" max="${MAX_DISCOUNT_PERCENT}" step="1" 
                                    class="w-16 h-8 text-center text-xs font-bold rounded-lg border border-[#dbe0e6] dark:border-gray-700 bg-white dark:bg-gray-900 focus:ring-primary focus:border-primary ${isZeroMargin ? 'opacity-30 pointer-events-none' : ''}" 
                                    value="${item.discountPercent}" 
                                    onchange="updateDiscount(${index}, this.value)">
                                <span class="ml-1 text-xs text-gray-500">%</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right text-sm font-medium text-[#617589] dark:text-gray-400">@symbol${item.price.toFixed(2)}</td>
                        <td class="px-6 py-4 text-right">
                             <div class="flex flex-col items-end">
                                <span class="text-sm font-black ${item.discountPercent > 0 ? 'text-orange-500' : 'text-[#111418] dark:text-white'}">@symbol${item.subtotal.toFixed(2)}</span>
                                ${item.discountPercent > 0 ? `<span class="text-[10px] text-gray-400 line-through">@symbol${originalSubtotal.toFixed(2)}</span>` : ''}
                             </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <button onclick="removeFromCart(${index})" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors opacity-0 group-hover:opacity-100">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </td>
                    `;
                    cartBody.appendChild(row);
                });
            }
            
            const totalToPay = cart.reduce((sum, item) => sum + item.subtotal, 0);
            totalDiscount = subtotalTotal - totalToPay;

            const formatMoney = (val) => '@symbol' + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            
            subtotalSpan.textContent = formatMoney(subtotalTotal);
            document.getElementById('summaryDiscount').textContent = formatMoney(totalDiscount);
            totalSpan.textContent = formatMoney(totalToPay);
            itemCountBadge.textContent = totalItems + ' Items';
        }

        function clearCart() {
            if(cart.length === 0) return;
            if(confirm('¿Seguro que desea vaciar el carrito?')) {
                cart = [];
                renderCart();
                clearSavedCart();
            }
        }

        async function processSale() {
            if (cart.length === 0) {
                showToast('Añade al menos un producto para cobrar', 'error');
                return;
            }

            // Validate cash register for cash payments
            if (cashRegisterRequired && selectedPaymentMethod === 'Cash' && !hasOpenCashRegister) {
                showToast('Debe abrir una caja antes de realizar ventas en efectivo.', 'error');
                return;
            }

            // Validate customer if required
            if (customerRequired && (!selectedCustomerId || selectedCustomerId === 0)) {
                showToast('Debe seleccionar un cliente para completar la venta.', 'error');
                return;
            }

            // Get selected customer
            selectedCustomerId = parseInt(document.getElementById('customerSelect').value);

            // Calculate totals
            const total = cart.reduce((sum, item) => sum + item.subtotal, 0);
            let amountPaid = total;
            let change = 0;

            // For cash payments, validate amount paid
            if (selectedPaymentMethod === 'Cash') {
                const amountInput = document.getElementById('amountPaid');
                amountPaid = parseFloat(amountInput.value) || 0;
                
                if (amountPaid < total) {
                    showToast('El monto recibido es menor al total de la venta.', 'error');
                    amountInput.focus();
                    return;
                }
                
                change = amountPaid - total;
            }

            if (!confirm('¿Procesar venta por ' + totalSpan.textContent + '?')) return;

            // Prepare Payload
            const payload = {
                CustomerId: selectedCustomerId,
                PaymentMethod: getPaymentMethodEnum(selectedPaymentMethod),
                AmountPaid: amountPaid,
                Change: change,
                SaleDetails: cart.map(i => ({
                    ProductId: i.productId,
                    Quantity: i.quantity,
                    DiscountPercent: i.discountPercent
                }))
            };

            try {
                const response = await fetch('@Url.Action("Create", "Sales")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const result = await response.json();
                    clearSavedCart(); // Clear saved cart on success
                    showToast('Venta procesada con éxito', 'success');
                    setTimeout(() => {
                    window.location.href = '/ventas/detalles/' + result.id;
                    }, 500);
                } else {
                    const error = await response.text();
                    showToast('Error: ' + error, 'error');
                }
            } catch (err) {
                showToast('Error de conexión: ' + err.message, 'error');
            }
        }

        // Payment Method Selection
        function selectPaymentMethod(method) {
            selectedPaymentMethod = method;
            
            // Update button states
            const buttons = ['btnCash', 'btnCard', 'btnTransfer', 'btnMixed'];
            buttons.forEach(btnId => {
                const btn = document.getElementById(btnId);
                btn.classList.remove('border-primary', 'bg-primary/5', 'text-primary');
                btn.classList.add('border-[#dbe0e6]', 'dark:border-gray-700', 'text-[#617589]');
            });
            
            const selectedBtn = document.getElementById('btn' + method);
            selectedBtn.classList.add('border-primary', 'bg-primary/5', 'text-primary');
            selectedBtn.classList.remove('border-[#dbe0e6]', 'dark:border-gray-700', 'text-[#617589]');
            
            // Show/hide cash amount section
            const cashSection = document.getElementById('cashAmountSection');
            if (method === 'Cash') {
                cashSection.classList.remove('hidden');
            } else {
                cashSection.classList.add('hidden');
            }
        }

        // Calculate Change
        function calculateChange() {
            const amountInput = document.getElementById('amountPaid');
            const amountPaid = parseFloat(amountInput.value) || 0;
            const total = cart.reduce((sum, item) => sum + item.subtotal, 0);
            const change = amountPaid - total;
            
            const changeDisplay = document.getElementById('changeDisplay');
            const changeAmount = document.getElementById('changeAmount');
            
            if (change >= 0 && amountPaid > 0) {
                changeDisplay.classList.remove('hidden');
                changeAmount.textContent = '@symbol' + change.toFixed(2);
            } else {
                changeDisplay.classList.add('hidden');
            }
        }

        // Get Payment Method Enum Value
        function getPaymentMethodEnum(method) {
            const enums = { 'Cash': 1, 'Card': 2, 'Transfer': 3, 'Mixed': 4 };
            return enums[method] || 1;
        }

        // Quick Create Customer Modal
        function quickCreateCustomer() {
            document.getElementById('quickCreateModal').classList.remove('hidden');
            document.getElementById('quickName').focus();
        }

        function closeQuickCreateModal() {
            document.getElementById('quickCreateModal').classList.add('hidden');
            document.getElementById('quickName').value = '';
            document.getElementById('quickNit').value = '';
            document.getElementById('quickPhone').value = '';
        }

        async function saveQuickCustomer() {
            const name = document.getElementById('quickName').value.trim();
            if (!name) {
                showToast('El nombre es requerido', 'error');
                return;
            }

            const payload = {
                Name: name,
                NitDpi: document.getElementById('quickNit').value.trim(),
                Phone: document.getElementById('quickPhone').value.trim()
            };

            try {
                const response = await fetch('/clientes/api/crear-rapido', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const result = await response.json();
                    
                    if (result.success) {
                        // Update local customers list (Map to PascalCase as used in initial load)
                        const mappedCustomer = {
                            Id: result.customer.id,
                            Name: result.customer.name,
                            NitDpi: result.customer.nitDpi,
                            Phone: result.customer.phone
                        };
                        allCustomers.push(mappedCustomer);
                        
                        // Select the new customer
                        selectCustomer(mappedCustomer.Id, mappedCustomer.Name, mappedCustomer.NitDpi);
                        
                        closeQuickCreateModal();
                        showToast('Cliente creado y seleccionado exitosamente', 'success');
                    }
                } else {
                    const error = await response.text();
                    showToast('Error: ' + error, 'error');
                }
            } catch (err) {
                showToast('Error de conexión: ' + err.message, 'error');
            }
        }

        // Update customer selection
        document.addEventListener('DOMContentLoaded', function() {
            const customerSelect = document.getElementById('customerSelect');
            if (customerSelect) {
                customerSelect.addEventListener('change', function() {
                    selectedCustomerId = parseInt(this.value);
                });
            }
        });

        // Shortcut Keys
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                processSale();
            }
            if (e.key === 'Escape') {
                searchInput.value = '';
                resultsDiv.classList.add('hidden');
            }
        });
    </script>
}
