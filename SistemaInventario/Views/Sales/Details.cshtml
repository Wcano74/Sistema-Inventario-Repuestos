@model SistemaInventario.Models.Entities.Sale
@inject SistemaInventario.Services.IConfigurationService Config
@{
    ViewData["Title"] = "Detalle de Venta";
    var nombreNegocio = await Config.GetConfigurationAsync("NombreNegocio", "Sistema de Inventario");
    var address = await Config.GetConfigurationAsync("DireccionNegocio", "");
    var phone = await Config.GetConfigurationAsync("TelefonoNegocio", "");
    var nit = await Config.GetConfigurationAsync("NITNegocio", "C/F");
    var message = await Config.GetConfigurationAsync("ReceiptMessage", "Gracias por su compra.");
    var symbol = await Config.GetCurrencySymbolAsync();
}

<style>
    @@media print {
        .no-print { display: none !important; }
        aside { display: none !important; }
        header { border-bottom: none !important; }
        .main-content { padding: 0 !important; }
        .invoice-card { border: none !important; shadow: none !important; }
    }
</style>

<!-- Page Heading & Actions (no-print) -->
<header class="no-print w-full bg-white/80 dark:bg-[#1a2632]/90 backdrop-blur-md sticky top-0 z-10 border-b border-[#dbe0e6] dark:border-gray-800 px-6 py-4">
    <div class="flex flex-wrap justify-between items-center gap-4 max-w-[1000px] mx-auto">
        <div class="flex flex-col gap-1">
            <h2 class="text-[#111418] dark:text-white text-2xl font-bold">Detalle de Venta</h2>
            <p class="text-[#617589] dark:text-gray-400 text-sm font-normal">Consulta y gestión de comprobante</p>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="window.print()" class="flex items-center justify-center gap-2 rounded-lg border border-[#dbe0e6] bg-white px-4 py-2 text-sm font-medium text-[#111418] hover:bg-gray-50 dark:border-gray-800 dark:bg-surface-dark dark:text-white dark:hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">print</span>
                Imprimir
            </button>
            <a asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white shadow-lg shadow-blue-500/20 transition-colors hover:bg-blue-600">
                <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                Nueva Venta
            </a>
        </div>
    </div>
</header>

<div class="p-6">
    <div class="mx-auto max-w-[800px]">
        <!-- Invoice Card -->
        <div class="invoice-card bg-white dark:bg-[#1a2632] rounded-3xl border border-[#dbe0e6] dark:border-gray-800 shadow-xl overflow-hidden p-8 sm:p-12">
            <!-- Invoice Header -->
            <div class="flex flex-col sm:flex-row justify-between gap-8 mb-12">
                <div class="flex flex-col gap-4">
                    <div class="flex items-center gap-3">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-white">
                            <span class="material-symbols-outlined text-[32px]">inventory_2</span>
                        </div>
                        <h1 class="text-2xl font-black text-[#111418] dark:text-white">@nombreNegocio</h1>
                    </div>
                    <div class="text-sm text-[#617589] dark:text-gray-400 leading-relaxed">
                        @address<br>
                        Tel: @phone<br>
                        NIT: @nit
                    </div>
                </div>
                <div class="flex flex-col sm:items-end gap-1">
                    <h2 class="text-4xl font-black text-gray-200 dark:text-gray-700 uppercase tracking-tighter mb-2">COMPROBANTE</h2>
                    <span class="text-sm font-bold text-[#617589] dark:text-gray-400">NÚMERO DE VENTA</span>
                    <span class="text-xl font-mono font-black text-primary">#@Model.Id.ToString("D5")</span>
                    <span class="text-sm font-medium text-[#617589] dark:text-gray-400 mt-2">FECHA DE EMISIÓN</span>
                    <span class="text-sm font-bold text-[#111418] dark:text-white">@Model.Date.ToString("dd MMMM yyyy, hh:mm tt")</span>
                </div>
            </div>

            <div class="h-px bg-[#f0f2f4] dark:bg-gray-800 mb-8"></div>

            <!-- Customer Info -->
            <div class="mb-10">
                <h3 class="text-xs font-bold text-[#617589] dark:text-gray-400 uppercase tracking-widest mb-4">CLIENTE</h3>
                <div class="flex flex-col gap-1">
                    <p class="text-lg font-bold text-[#111418] dark:text-white">@(Model.Customer?.Name ?? "Cliente General")</p>
                    <p class="text-sm text-[#617589] dark:text-gray-400">@(Model.Customer?.NitDpi ?? "C/F")</p>
                </div>
            </div>

            <!-- Items Table -->
            <div class="mb-10 overflow-hidden">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[11px] font-bold text-[#617589] dark:text-gray-400 uppercase tracking-widest border-b border-[#f0f2f4] dark:border-gray-800">
                            <th class="pb-4">DESCRIPCIÓN</th>
                            <th class="pb-4 text-center">CANT.</th>
                            <th class="pb-4 text-right">PRECIO UNIT.</th>
                            <th class="pb-4 text-right">SUBTOTAL</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#f0f2f4] dark:divide-gray-800">
                        @foreach (var detail in Model.SaleDetails)
                        {
                            <tr>
                                <td class="py-5 font-medium text-[#111418] dark:text-white">@detail.Product?.Name</td>
                                <td class="py-5 text-center text-[#111418] dark:text-white">@detail.Quantity</td>
                                <td class="py-5 text-right text-[#617589] dark:text-gray-400">@symbol@detail.UnitPrice.ToString("N2")</td>
                                <td class="py-5 text-right font-bold text-[#111418] dark:text-white">@symbol@detail.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Totals Section -->
            <div class="flex flex-col sm:flex-row justify-between gap-8 pt-8 border-t-2 border-[#111418] dark:border-white">
                <div class="flex-1">
                    <p class="text-sm italic text-[#617589] dark:text-gray-500 mb-4">"@message"</p>
                </div>
                <div class="w-full sm:w-64 flex flex-col gap-4">
                    <div class="flex justify-between items-center text-[#617589] dark:text-gray-400">
                        <span class="text-sm font-bold">SUBTOTAL</span>
                        <span class="font-medium">@symbol@Model.Total.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between items-center text-[#617589] dark:text-gray-400">
                        <span class="text-sm font-bold">DESCUENTO</span>
                        <span class="font-medium">@symbol@("0.00")</span>
                    </div>
                    <div class="h-px bg-[#f0f2f4] dark:bg-gray-800 my-1"></div>
                    <div class="flex justify-between items-center py-2 px-4 bg-primary text-white rounded-xl shadow-lg shadow-blue-500/20">
                        <span class="text-base font-black">TOTAL</span>
                        <span class="text-2xl font-black">@symbol@Model.Total.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <!-- Footer Note -->
            <div class="mt-16 text-center">
                <div class="inline-block px-6 py-2 rounded-full bg-gray-50 dark:bg-gray-800 text-[10px] font-bold text-[#617589] dark:text-gray-500 uppercase tracking-widest">
                    Documento • Generado por SistemaInventario POS
                </div>
            </div>
        </div>
        
        <!-- Bottom Actions (no-print) -->
        <div class="no-print mt-8 flex justify-center gap-4">
             <a asp-action="Index" class="flex items-center gap-2 text-sm font-bold text-[#617589] hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                Cerrar y Volver al Historial
            </a>
        </div>
    </div>
</div>
